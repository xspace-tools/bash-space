#!/usr/bin/env bash
# animate-space/bin/animatex
#
# Primary entry point for all animatex tools.
# Type 'animatex' and you'll be asked what you want to generate.
#
# Direct usage (skips the type menu):
#   animatex --type text [options]
#   animatex --type svg  [options]
#   animatex --help
#   animatex --version

# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v0.4.0 — Moved from x-space/bin/ to animate-space/bin/. SPACE_DIR now
#             resolves to animate-space/ (one up from bin/). XSPACE_ROOT is
#             one further up. Lib sourced from animate-space/lib/.
#   v0.3.0 — Single entry point with type-selection menu.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# BOOTSTRAP
# ─────────────────────────────────────────────────────────────────────────────
# readlink -f resolves the ~/bin symlink so path walk always succeeds.
# SPACE_DIR  = animate-space/   (one up from bin/)
# XSPACE_ROOT = xspace/          (one further up — where xspace.conf lives)

_REAL_BIN="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
SPACE_DIR="$(cd "$_REAL_BIN/.." && pwd)"
XSPACE_ROOT="$(cd "$SPACE_DIR/.." && pwd)"

CONF="$XSPACE_ROOT/xspace.conf"
if [[ ! -f "$CONF" ]]; then
    echo "animatex: xspace.conf not found at $CONF"
    echo "          Re-run x-space/install.sh"
    exit 1
fi
source "$CONF"

LIB="$SPACE_DIR/lib/animatex.sh"
if [[ ! -f "$LIB" ]]; then
    echo "animatex: lib/animatex.sh not found at $LIB"
    echo "          Expected: animate-space/lib/animatex.sh"
    exit 1
fi
source "$LIB"

# ─────────────────────────────────────────────────────────────────────────────
# ROUTE
# ─────────────────────────────────────────────────────────────────────────────

case "${1:-run}" in
    --help|-h|help)       animatex_help ;;
    --version|-v|version) echo "animatex v0.4.0" ;;
    *)                    animatex_run "$@" ;;
esac
