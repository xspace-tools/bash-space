#!/usr/bin/env bash
# animate-space/bin/animatex
#
# Primary entry point for all animatex tools.
# Sources lib/animatex.sh which auto-discovers all available engine types
# and presents a menu. Adding a new animate-* engine dir makes it appear
# in the menu automatically — no changes needed here.
#
# Direct usage (skips the menu):
#   animatex --type text [options]
#   animatex --type svg  [options]
#   animatex --help
#   animatex --version

# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v0.5.0 — Error messages updated to reference _configure/install.sh.
#             No bootstrap logic changes — lib/animatex.sh now handles all
#             engine discovery internally.
#   v0.4.0 — Moved from x-space/bin/ to animate-space/bin/.
#   v0.3.0 — Single entry point with type-selection menu.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# BOOTSTRAP
# ─────────────────────────────────────────────────────────────────────────────
# SPACE_DIR  = animate-space/   (one up from bin/)
# XSPACE_ROOT = xspace/          (two up — where xspace.conf lives)

_REAL_BIN="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
SPACE_DIR="$(cd "$_REAL_BIN/.." && pwd)"
XSPACE_ROOT="$(cd "$SPACE_DIR/.." && pwd)"

CONF="$XSPACE_ROOT/xspace.conf"
if [[ ! -f "$CONF" ]]; then
    echo "animatex: xspace.conf not found at $CONF"
    echo "          Re-run _configure/install.sh"
    exit 1
fi
source "$CONF"

LIB="$SPACE_DIR/lib/animatex.sh"
if [[ ! -f "$LIB" ]]; then
    echo "animatex: animate-space/lib/animatex.sh not found"
    echo "          Expected at: $LIB"
    echo "          Re-run _configure/install.sh"
    exit 1
fi
source "$LIB"

# ─────────────────────────────────────────────────────────────────────────────
# ROUTE
# ─────────────────────────────────────────────────────────────────────────────

case "${1:-run}" in
    --help|-h|help)       animatex_help ;;
    --version|-v|version) echo "animatex v0.5.0" ;;
    *)                    animatex_run "$@" ;;
esac
