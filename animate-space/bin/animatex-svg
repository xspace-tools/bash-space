#!/usr/bin/env bash
# animate-space/bin/animatex-svg
#
# Direct shortcut for animated SVG/HTML generation.
# Sources the engine lib directly from animate-svg/ — bypasses the menu.
#
# Usage:
#   animatex-svg                         interactive
#   animatex-svg --brand "#00CC66" ...   direct / scriptable
#   animatex-svg --format html
#   animatex-svg --help

# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v0.3.0 — Engine lib path updated: now sources directly from
#             animate-space/animate-svg/animatex_svg.sh (moved from lib/).
#             Error message updated to reference _configure/install.sh.
#   v0.2.0 — Moved from x-space/bin/ to animate-space/bin/.
#   v0.1.0 — Initial release.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

_REAL_BIN="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
SPACE_DIR="$(cd "$_REAL_BIN/.." && pwd)"
XSPACE_ROOT="$(cd "$SPACE_DIR/.." && pwd)"

CONF="$XSPACE_ROOT/xspace.conf"
if [[ ! -f "$CONF" ]]; then
    echo "animatex-svg: xspace.conf not found at $CONF"
    echo "              Re-run _configure/install.sh"
    exit 1
fi
source "$CONF"

# Source directly from the engine's own directory
ENGINE_LIB="$SPACE_DIR/animate-svg/animatex_svg.sh"
if [[ ! -f "$ENGINE_LIB" ]]; then
    echo "animatex-svg: engine lib not found at $ENGINE_LIB"
    echo "              Expected: animate-space/animate-svg/animatex_svg.sh"
    exit 1
fi
source "$ENGINE_LIB"

case "${1:-run}" in
    --help|-h|help)       animatex_svg_help ;;
    --version|-v|version) echo "animatex-svg v0.3.0" ;;
    *)                    animatex_svg_run "$@" ;;
esac
