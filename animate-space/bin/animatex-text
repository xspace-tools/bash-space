#!/usr/bin/env bash
# animate-space/bin/animatex-text
#
# Direct shortcut for animated GIF generation.
# Bypasses the type menu — goes straight to GIF prompt.
#
# Usage:
#   animatex-text                          interactive
#   animatex-text --brand "#00CC66" ...    direct / scriptable
#   animatex-text --help

# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v0.2.0 — Moved from x-space/bin/ to animate-space/bin/. SPACE_DIR
#             resolves to animate-space/. Lib at animate-space/lib/.
#   v0.1.0 — Initial release.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

_REAL_BIN="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
SPACE_DIR="$(cd "$_REAL_BIN/.." && pwd)"
XSPACE_ROOT="$(cd "$SPACE_DIR/.." && pwd)"

CONF="$XSPACE_ROOT/xspace.conf"
[[ ! -f "$CONF" ]] && echo "animatex-text: xspace.conf not found at $CONF" && exit 1
source "$CONF"

LIB="$SPACE_DIR/lib/animatex_text.sh"
[[ ! -f "$LIB" ]] && echo "animatex-text: lib/animatex_text.sh not found" && exit 1
source "$LIB"

case "${1:-run}" in
    --help|-h|help)       animatex_text_help ;;
    --version|-v|version) echo "animatex-text v0.2.0" ;;
    *)                    animatex_text_run "$@" ;;
esac
