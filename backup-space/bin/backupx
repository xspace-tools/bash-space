#!/usr/bin/env bash
# backup-space/bin/backupx
#
# Interactive backup orchestrator with archive-sync behaviour.
# Reads job definitions from backup-space/config/backups.conf.
#
# Archive-sync: pushes local → dest. Files deleted locally are moved to
# dest/_archivex/YYYYMMDD_filename — never silently deleted.
#
# Supported methods : rclone | rsync | tar
# OS support        : Linux (Fedora) · macOS · Windows (Git Bash / MSYS2)

# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v0.3.0 — Full rewrite. Interactive guided job-selection menu. Archive-sync
#             replaces copy/sync: deletions in dest moved to _archivex/ (not
#             deleted). Cross-platform: Linux/macOS/Windows Git Bash. LOCAL_BASE
#             auto-resolved per OS (~/_ or ~/Desktop/_). {LOCAL_BASE} and
#             {RCLONE_REMOTE} placeholders expanded at runtime. --init flag for
#             first-run remote→local pull. Rclone auth check before any cloud
#             job. Named jobs + ## group headers in conf. --parallel flag for
#             concurrent execution. Summary report. CONFIG block.
#   v0.2.0 — Moved to backup-space/bin/. Fixed conf path via BASH_SOURCE[0].
#             Added --help, --list, --dry-run flags.
#   v0.1.0 — Initial release.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail
IFS=$'\n\t'

# ─────────────────────────────────────────────────────────────────────────────
# BOOTSTRAP — resolve SPACE_DIR from script location (portable, rename-safe)
# ─────────────────────────────────────────────────────────────────────────────

# readlink -f is GNU; macOS needs greadlink. Windows Git Bash has it natively.
_resolve_bin() {
  if command -v readlink &>/dev/null && readlink -f "${BASH_SOURCE[0]}" &>/dev/null 2>&1; then
    cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd
  else
    cd "$(dirname "${BASH_SOURCE[0]}")" && pwd
  fi
}

_REAL_BIN="$(_resolve_bin)"
SPACE_DIR="$(cd "$_REAL_BIN/.." && pwd)"
XSPACE_ROOT="$(cd "$SPACE_DIR/.." && pwd)"

# ─────────────────────────────────────────────────────────────────────────────
# OS DETECTION
# ─────────────────────────────────────────────────────────────────────────────

_detect_os() {
  case "$(uname -s 2>/dev/null)" in
    Linux*)           echo "linux"   ;;
    Darwin*)          echo "mac"     ;;
    MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
    *)                echo "unknown" ;;
  esac
}
OS="$(_detect_os)"

# ─────────────────────────────────────────────────────────────────────────────
# CONFIG
# ─────────────────────────────────────────────────────────────────────────────

CONF="$SPACE_DIR/config/backups.conf"
LOG_DIR="$SPACE_DIR/logs"
DATE_PREFIX="$(date +'%Y%m%d')"

# rclone remote name as configured via `rclone config`
RCLONE_REMOTE="onedrive-sconl"

# Archive folder name — lives only at the destination, never locally
ARCHIVEX_DIR="_archivex"

# Local base: where synced folders live on this machine
# Linux/macOS: ~/_ · Windows (Git Bash): ~/Desktop/_
case "$OS" in
  windows) LOCAL_BASE="$HOME/Desktop/_" ;;
  *)       LOCAL_BASE="$HOME/_"         ;;
esac

mkdir -p "$LOG_DIR"

# ─────────────────────────────────────────────────────────────────────────────
# COLORS & UI
# ─────────────────────────────────────────────────────────────────────────────

if [[ -t 1 && "${NO_COLOR:-}" != "1" ]]; then
  R=$'\033[0m'      BOLD=$'\033[1m'    DIM=$'\033[2m'
  GRN=$'\033[0;32m' YLW=$'\033[0;33m' BLU=$'\033[0;34m'
  CYN=$'\033[0;36m' RED=$'\033[0;31m' WHT=$'\033[1;37m'
  GRY=$'\033[0;90m' MGT=$'\033[0;35m'
else
  R='' BOLD='' DIM='' GRN='' YLW='' BLU='' CYN='' RED='' WHT='' GRY='' MGT=''
fi

_ok()   { echo -e "  ${GRN}✓${R}  $*"; }
_info() { echo -e "  ${BLU}→${R}  $*"; }
_warn() { echo -e "  ${YLW}⚠${R}   $*"; }
_err()  { echo -e "  ${RED}✗${R}  $*" >&2; }
_dim()  { echo -e "     ${GRY}$*${R}"; }
_hr()   { echo -e "\n  ${DIM}────────────────────────────────────────────────────────${R}"; }

_banner() {
  local ts
  ts="$(date +'%B %d, %Y · %I:%M %p')"
  echo ""
  echo -e "  ${BOLD}${WHT}backupx${R}${GRY} — xspace backup orchestrator${R}"
  echo -e "  ${DIM}${ts}${R}"
  echo -e "  ${GRY}local base : ${CYN}${LOCAL_BASE}${R}"
  echo -e "  ${GRY}remote     : ${CYN}${RCLONE_REMOTE}:${R}"
  echo ""
}

# ─────────────────────────────────────────────────────────────────────────────
# FLAGS
# ─────────────────────────────────────────────────────────────────────────────

DRY_RUN=false
LIST_ONLY=false
DO_INIT=false
PARALLEL=false
SELECTED_JOBS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run|-n)  DRY_RUN=true;   shift ;;
    --list|-l)     LIST_ONLY=true; shift ;;
    --init)        DO_INIT=true;   shift ;;
    --parallel|-p) PARALLEL=true;  shift ;;
    --help|-h)
      cat <<'HELP'

  backupx — xspace backup orchestrator

  USAGE
    backupx              interactive: choose jobs, then run
    backupx --init       first-run setup — pull remote folders to local
    backupx --list       list all configured jobs (no execution)
    backupx --dry-run    show what would run, touch nothing
    backupx --parallel   run all selected jobs concurrently
    backupx --help

  ARCHIVE-SYNC BEHAVIOUR
    Local is always the source of truth. Backups push local → destination.
    Files deleted locally are NOT removed at the destination — they are
    moved into  dest/_archivex/YYYYMMDD_filename  instead.
    The _archivex folder is created automatically and lives only at the
    destination — never in your local working copy.

  CONFIG
    Edit:   backup-space/config/backups.conf
    Format: name|method|source|dest|options

    {LOCAL_BASE}    expands to OS-appropriate synced-files base directory
                    Linux/macOS → ~/_ · Windows → ~/Desktop/_
    {RCLONE_REMOTE} expands to the RCLONE_REMOTE value set in this script

  RCLONE REMOTE
    Set RCLONE_REMOTE in this script's CONFIG block (currently: onedrive).
    Run  rclone config  to set up or verify your remote.
    Run  backupx --init  to do the first pull of remote folders to local.

  FIRST-TIME SETUP
    1.  rclone config              # authenticate OneDrive
    2.  backupx --init             # pull all remote folders to local
    3.  backupx                    # run backups going forward

  LOGS
    backup-space/logs/YYYYMMDD_backupx_<name>.log

HELP
      exit 0
      ;;
    *) _err "unknown option '$1' — try --help"; exit 1 ;;
  esac
done

# ─────────────────────────────────────────────────────────────────────────────
# PREFLIGHT
# ─────────────────────────────────────────────────────────────────────────────

if [[ ! -f "$CONF" ]]; then
  _err "backups.conf not found at $CONF"
  echo ""
  echo -e "  ${GRY}Expected: ${CYN}$CONF${R}"
  exit 1
fi

# ─────────────────────────────────────────────────────────────────────────────
# CONF PARSER
# ─────────────────────────────────────────────────────────────────────────────
# Populates parallel arrays from backups.conf.
# Format : name|method|source|dest|options
# Headers: ## Group Name  (displayed in UI; not executed)

JOB_NAMES=()
JOB_METHODS=()
JOB_SOURCES=()
JOB_DESTS=()
JOB_OPTIONS=()
JOB_GROUPS=()

_trim() {
  local s="$1"
  s="${s#"${s%%[^[:space:]]*}"}"
  s="${s%"${s##*[^[:space:]]}"}"
  printf '%s' "$s"
}

_parse_conf() {
  local current_group="General"
  local idx=0

  while IFS= read -r raw || [[ -n "${raw:-}" ]]; do
    local line="${raw:-}"

    # Skip blank lines
    [[ -z "${line//[[:space:]]/}" ]] && continue

    # Skip pure comment lines (but not ## headers)
    if [[ "$line" =~ ^[[:space:]]*#[^#] || "$line" =~ ^[[:space:]]*#$ ]]; then
      continue
    fi

    # ## Group headers
    if [[ "$line" =~ ^##[[:space:]]+(.*) ]]; then
      current_group="${BASH_REMATCH[1]}"
      current_group="$(_trim "$current_group")"
      continue
    fi

    # Data line: name|method|source|dest|options
    local name method source dest options
    IFS='|' read -r name method source dest options <<< "$line"

    name="$(_trim "${name:-}")"
    method="$(_trim "${method:-}")"
    source="$(_trim "${source:-}")"
    dest="$(_trim "${dest:-}")"
    options="$(_trim "${options:-}")"

    # Skip incomplete or comment-looking lines
    [[ -z "$name" || -z "$method" ]] && continue
    [[ "$name" == \#* ]] && continue

    # Expand placeholders
    source="${source//\{LOCAL_BASE\}/$LOCAL_BASE}"
    dest="${dest//\{LOCAL_BASE\}/$LOCAL_BASE}"
    dest="${dest//\{RCLONE_REMOTE\}/$RCLONE_REMOTE}"

    JOB_NAMES+=("$name")
    JOB_METHODS+=("$method")
    JOB_SOURCES+=("$source")
    JOB_DESTS+=("$dest")
    JOB_OPTIONS+=("$options")
    JOB_GROUPS+=("$current_group")

    (( idx++ )) || true
  done < "$CONF"
}

# ─────────────────────────────────────────────────────────────────────────────
# JOB DISPLAY (used by --list and interactive menu)
# ─────────────────────────────────────────────────────────────────────────────

_display_jobs() {
  local total="${#JOB_NAMES[@]}"
  local prev_group=""
  local i

  for (( i=0; i<total; i++ )); do
    local group="${JOB_GROUPS[$i]}"
    local name="${JOB_NAMES[$i]}"
    local method="${JOB_METHODS[$i]}"
    local source="${JOB_SOURCES[$i]}"
    local dest="${JOB_DESTS[$i]}"

    if [[ "$group" != "$prev_group" ]]; then
      echo ""
      echo -e "  ${DIM}${group}${R}"
      prev_group="$group"
    fi

    printf "  ${CYN}[%2d]${R}  ${WHT}%-28s${R}  ${GRY}%-6s${R}  ${DIM}%s${R}\n" \
      $((i+1)) "$name" "$method" "$dest"
  done
}

# ─────────────────────────────────────────────────────────────────────────────
# INTERACTIVE JOB SELECTION
# ─────────────────────────────────────────────────────────────────────────────

_select_jobs() {
  local total="${#JOB_NAMES[@]}"

  _banner

  echo -e "  ${BOLD}Which backups would you like to run?${R}"
  _hr

  echo ""
  echo -e "  ${GRN}[ 0]${R}  ${BOLD}Run all${R}  ${DIM}(default — just press Enter)${R}"

  _display_jobs

  echo ""
  _hr
  echo ""
  echo -e "  ${GRY}Enter numbers separated by spaces (e.g. ${WHT}1 3 5${R}${GRY}),"
  echo -e "  press ${WHT}Enter${R}${GRY} or type ${WHT}0${R}${GRY} to run everything.${R}"
  echo ""
  printf "  ${CYN}›${R} "

  local input
  read -r input

  # Default / all
  if [[ -z "$input" || "$input" == "0" ]]; then
    SELECTED_JOBS=()
    return
  fi

  local selected=()
  for token in $input; do
    if [[ "$token" =~ ^[0-9]+$ ]] && (( token > 0 && token <= total )); then
      selected+=("$(( token - 1 ))")
    elif [[ "$token" =~ ^[0-9]+$ ]]; then
      _warn "Job $token does not exist — skipping"
    fi
  done

  SELECTED_JOBS=( "${selected[@]+"${selected[@]}"}" )
}

# ─────────────────────────────────────────────────────────────────────────────
# RCLONE HELPERS
# ─────────────────────────────────────────────────────────────────────────────

_rclone_ok() { command -v rclone &>/dev/null; }

_check_rclone_auth() {
  echo ""

  if ! _rclone_ok; then
    _err "rclone is not installed."
    echo ""
    echo -e "  ${GRY}Install from: ${CYN}https://rclone.org/install/${R}"
    echo -e "  ${GRY}Fedora:   ${CYN}sudo dnf install rclone${R}"
    echo -e "  ${GRY}Windows:  ${CYN}winget install Rclone.Rclone${R}"
    return 1
  fi

  # ── Remote not configured → offer to run rclone config now ───────────────
  if ! rclone listremotes 2>/dev/null | grep -qF "${RCLONE_REMOTE}:"; then
    _err "rclone remote '${RCLONE_REMOTE}' is not configured."
    echo ""
    echo -e "  ${GRY}This remote needs to be created once via ${CYN}rclone config${R}${GRY}.${R}"
    echo -e "  ${GRY}When prompted, choose: ${WHT}Microsoft OneDrive${R}${GRY}, name it ${WHT}${RCLONE_REMOTE}${R}${GRY}.${R}"
    echo ""
    printf "  ${CYN}Run rclone config now?${R} ${GRY}[Y/n]${R} "
    local yn; read -r yn
    if [[ "${yn:-y}" =~ ^[Yy]$ || -z "$yn" ]]; then
      echo ""
      rclone config
      echo ""
      # Re-check after config completes
      if rclone listremotes 2>/dev/null | grep -qF "${RCLONE_REMOTE}:"; then
        _ok "Remote '${RCLONE_REMOTE}' configured."
      else
        _err "Remote '${RCLONE_REMOTE}' still not found after config — exiting."
        return 1
      fi
    else
      return 1
    fi
  fi

  # ── Token expired → offer to reconnect ───────────────────────────────────
  _info "Verifying OneDrive connection..."
  if ! rclone lsd "${RCLONE_REMOTE}:" --max-depth=1 &>/dev/null; then
    _err "Cannot reach '${RCLONE_REMOTE}:' — token may have expired."
    echo ""
    printf "  ${CYN}Reconnect now? (rclone config reconnect)${R} ${GRY}[Y/n]${R} "
    local yn; read -r yn
    if [[ "${yn:-y}" =~ ^[Yy]$ || -z "$yn" ]]; then
      echo ""
      rclone config reconnect "${RCLONE_REMOTE}:"
      echo ""
      if ! rclone lsd "${RCLONE_REMOTE}:" --max-depth=1 &>/dev/null; then
        _err "Still cannot connect — check your network and try again."
        return 1
      fi
    else
      return 1
    fi
  fi

  _ok "OneDrive connected  ${GRY}(${RCLONE_REMOTE}:)${R}"
  return 0
}

# ─────────────────────────────────────────────────────────────────────────────
# INITIAL SETUP (--init): remote → local first pull
# ─────────────────────────────────────────────────────────────────────────────

_init_setup() {
  _banner
  echo -e "  ${BOLD}Initial setup — pulling remote folders to local${R}"
  echo -e "  ${GRY}This is a one-time operation. Run ${CYN}backupx${R}${GRY} afterward for ongoing backups.${R}"

  _check_rclone_auth || exit 1

  local total="${#JOB_NAMES[@]}"
  local pulled=0 failed=0

  for (( i=0; i<total; i++ )); do
    local method="${JOB_METHODS[$i]}"
    [[ "$method" != "rclone" ]] && continue

    local name="${JOB_NAMES[$i]}"
    local source="${JOB_SOURCES[$i]}"
    local dest="${JOB_DESTS[$i]}"
    local log_file="$LOG_DIR/${DATE_PREFIX}_backupx_init_${name}.log"

    echo ""
    echo -e "  ${BOLD}${WHT}${name}${R}"
    echo -e "  ${GRY}remote → ${CYN}${source}${R}"

    if [[ "$DRY_RUN" == true ]]; then
      _dim "[dry-run] rclone copy $dest $source"
      continue
    fi

    mkdir -p "$source"

    if rclone copy "$dest" "$source" --progress 2>>"$log_file"; then
      _ok "Pulled to: ${source}"
      (( pulled++ )) || true
    else
      _warn "Pull failed — see: $(basename "$log_file")"
      (( failed++ )) || true
    fi
  done

  echo ""
  _hr
  echo ""
  [[ $pulled -gt 0 ]] && _ok "$pulled folder(s) pulled to ${LOCAL_BASE}"
  [[ $failed -gt 0 ]] && _warn "$failed failed — check logs in $LOG_DIR"
  echo ""
  echo -e "  ${GRY}Next step: run ${CYN}backupx${R}${GRY} to start syncing.${R}"
  echo ""
}

# ─────────────────────────────────────────────────────────────────────────────
# ARCHIVE-SYNC: RCLONE (local → cloud)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Find files in dest that do not exist in source (deletions).
# 2. Move each to dest/_archivex/YYYYMMDD_filename.
# 3. Sync source → dest (excluding _archivex/).

_archive_sync_rclone() {
  local name="$1" source="$2" dest="$3" options="$4" log_file="$5"

  # ── Step 1: detect deletions ─────────────────────────────────────────────
  _dim "Scanning for remote-only files..."

  local dest_files src_files to_archive
  dest_files="$(rclone lsf "$dest" --recursive \
    --exclude "${ARCHIVEX_DIR}/**" \
    2>>"$log_file" | grep -v '/$' | LC_ALL=C sort || true)"

  src_files="$(rclone lsf "$source" --recursive \
    2>>"$log_file" | grep -v '/$' | LC_ALL=C sort || true)"

  to_archive=""
  if [[ -n "$dest_files" ]]; then
    if [[ -n "$src_files" ]]; then
      to_archive="$(LC_ALL=C comm -23 \
        <(printf '%s\n' "$dest_files") \
        <(printf '%s\n' "$src_files") 2>/dev/null || true)"
    else
      to_archive="$dest_files"
    fi
  fi

  # ── Step 2: archive deletions ────────────────────────────────────────────
  if [[ -n "$to_archive" ]]; then
    local count=0
    while IFS= read -r file; do
      [[ -z "$file" ]] && continue
      local bname="${file##*/}"
      local archived="${DATE_PREFIX}_${bname}"
      _dim "archiving → ${ARCHIVEX_DIR}/${archived}  (was: ${file})"
      if [[ "$DRY_RUN" != true ]]; then
        rclone moveto \
          "$dest/$file" \
          "$dest/${ARCHIVEX_DIR}/${archived}" \
          >>"$log_file" 2>&1 || _warn "Could not archive: $file"
      fi
      (( count++ )) || true
    done <<< "$to_archive"
    _info "$count deleted file(s) archived to ${ARCHIVEX_DIR}/"
  else
    _dim "No deletions detected."
  fi

  # ── Step 3: sync local → remote ──────────────────────────────────────────
  _info "Syncing → ${dest}"

  if [[ "$DRY_RUN" == true ]]; then
    _dim "[dry-run] rclone sync $source $dest"
    return 0
  fi

  # shellcheck disable=SC2086
  rclone sync "$source" "$dest" \
    $options \
    --exclude "${ARCHIVEX_DIR}/**" \
    >>"$log_file" 2>&1
}

# ─────────────────────────────────────────────────────────────────────────────
# ARCHIVE-SYNC: RSYNC (local → local or local → SSH)
# ─────────────────────────────────────────────────────────────────────────────
# Uses rsync --dry-run to identify deletions first, moves them to _archivex/,
# then syncs. This avoids rsync ever actually deleting anything.

_archive_sync_rsync() {
  local name="$1" source="$2" dest="$3" options="$4" log_file="$5"
  local archive_dir="${dest}/${ARCHIVEX_DIR}"

  mkdir -p "$dest" "$archive_dir"

  # ── Step 1: detect deletions ─────────────────────────────────────────────
  _dim "Scanning for destination-only items..."

  local to_archive
  # shellcheck disable=SC2086
  to_archive="$(rsync -a --delete --dry-run \
    --exclude="${ARCHIVEX_DIR}/" \
    $options \
    "${source}/" "${dest}/" 2>>"$log_file" \
    | awk '/^deleting / { sub(/^deleting /, ""); print }' || true)"

  # ── Step 2: move to archive ──────────────────────────────────────────────
  if [[ -n "$to_archive" ]]; then
    local count=0
    while IFS= read -r item; do
      [[ -z "$item" ]] && continue
      local bname="${item##*/}"
      local archived="${DATE_PREFIX}_${bname}"
      _dim "archiving → ${ARCHIVEX_DIR}/${archived}  (was: ${item})"
      if [[ "$DRY_RUN" != true ]]; then
        if [[ -e "${dest}/${item}" ]]; then
          mv "${dest}/${item}" "${archive_dir}/${archived}"
        fi
      fi
      (( count++ )) || true
    done <<< "$to_archive"
    _info "$count deleted item(s) archived to ${ARCHIVEX_DIR}/"
  else
    _dim "No deletions detected."
  fi

  # ── Step 3: sync (safe — nothing left to delete) ─────────────────────────
  _info "Syncing → ${dest}"

  if [[ "$DRY_RUN" == true ]]; then
    _dim "[dry-run] rsync $source → $dest"
    return 0
  fi

  # shellcheck disable=SC2086
  rsync -a $options \
    --exclude="${ARCHIVEX_DIR}/" \
    "${source}/" "${dest}/" \
    >>"$log_file" 2>&1
}

# ─────────────────────────────────────────────────────────────────────────────
# TAR (compressed archive)
# ─────────────────────────────────────────────────────────────────────────────
# Previous archive file is moved to _archivex/ before creating a new one.

_run_tar() {
  local name="$1" source="$2" dest="$3" options="$4" log_file="$5"
  local dest_dir dest_base archive_dir

  dest_dir="$(dirname "$dest")"
  dest_base="$(basename "$dest")"
  archive_dir="${dest_dir}/${ARCHIVEX_DIR}"

  mkdir -p "$dest_dir" "$archive_dir"

  # Archive the previous version before overwriting
  if [[ -f "$dest" ]]; then
    local archived="${DATE_PREFIX}_${dest_base}"
    _dim "archiving previous → ${ARCHIVEX_DIR}/${archived}"
    if [[ "$DRY_RUN" != true ]]; then
      mv "$dest" "${archive_dir}/${archived}"
    fi
  fi

  _info "Creating archive → ${dest}"

  if [[ "$DRY_RUN" == true ]]; then
    _dim "[dry-run] tar czf $dest $source"
    return 0
  fi

  # shellcheck disable=SC2086
  tar czf "$dest" $options "$source" >>"$log_file" 2>&1
}

# ─────────────────────────────────────────────────────────────────────────────
# RUN A SINGLE JOB
# ─────────────────────────────────────────────────────────────────────────────

_run_job() {
  local idx="$1"
  local name="${JOB_NAMES[$idx]}"
  local method="${JOB_METHODS[$idx]}"
  local source="${JOB_SOURCES[$idx]}"
  local dest="${JOB_DESTS[$idx]}"
  local options="${JOB_OPTIONS[$idx]}"
  local log_file="${LOG_DIR}/${DATE_PREFIX}_backupx_${name}.log"

  echo ""
  echo -e "  ${BOLD}${WHT}${name}${R}  ${GRY}(${method})${R}"
  echo -e "  ${GRY}${source}${R}"
  echo -e "  ${GRY}→ ${CYN}${dest}${R}"

  local job_ok=true

  case "$method" in
    rclone)
      if ! _rclone_ok; then
        _warn "rclone not installed — skipping '${name}'"
        return 1
      fi
      _archive_sync_rclone "$name" "$source" "$dest" "$options" "$log_file" || job_ok=false
      ;;
    rsync)
      if ! command -v rsync &>/dev/null; then
        _warn "rsync not installed — skipping '${name}'"
        return 1
      fi
      _archive_sync_rsync "$name" "$source" "$dest" "$options" "$log_file" || job_ok=false
      ;;
    tar)
      _run_tar "$name" "$source" "$dest" "$options" "$log_file" || job_ok=false
      ;;
    *)
      _warn "Unknown method '${method}' — skipping '${name}'"
      return 1
      ;;
  esac

  if [[ "$job_ok" == true ]]; then
    _ok "Done  ${GRY}→ log: $(basename "$log_file")${R}"
    return 0
  else
    _err "Failed  ${GRY}→ log: $(basename "$log_file")${R}"
    return 1
  fi
}

# ─────────────────────────────────────────────────────────────────────────────
# INIT GATE — detect uninitialized local folders and prompt
# ─────────────────────────────────────────────────────────────────────────────
# Called after job selection. Checks whether any selected rclone job's local
# source directory is missing. If so, offers to run --init right now.

_check_needs_init() {
  local indices=("$@")
  local missing_names=() missing_paths=()

  for idx in "${indices[@]}"; do
    [[ "${JOB_METHODS[$idx]}" != "rclone" ]] && continue
    local src="${JOB_SOURCES[$idx]}"
    if [[ ! -d "$src" ]]; then
      missing_names+=("${JOB_NAMES[$idx]}")
      missing_paths+=("$src")
    fi
  done

  [[ ${#missing_names[@]} -eq 0 ]] && return 0  # all good

  echo ""
  _warn "${#missing_names[@]} local folder(s) have not been pulled yet:"
  local i
  for (( i=0; i<${#missing_names[@]}; i++ )); do
    echo -e "     ${GRY}· ${WHT}${missing_names[$i]}${R}  ${GRY}→ ${missing_paths[$i]}${R}"
  done
  echo ""
  echo -e "  ${GRY}Run ${CYN}backupx --init${R}${GRY} to pull them from OneDrive first,${R}"
  echo -e "  ${GRY}then run ${CYN}backupx${R}${GRY} for ongoing backups.${R}"
  echo ""
  printf "  ${CYN}Run --init now?${R} ${GRY}[Y/n]${R} "
  local yn; read -r yn

  if [[ "${yn:-y}" =~ ^[Yy]$ || -z "$yn" ]]; then
    echo ""
    _init_setup
    echo ""
    echo -e "  ${GRY}Resuming backup run...${R}"
    echo ""
  else
    echo ""
    echo -e "  ${GRY}Skipping missing folders. Jobs without a local source will fail.${R}"
    echo ""
  fi
}

# ─────────────────────────────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────────────────────────────

_parse_conf

total_jobs="${#JOB_NAMES[@]}"

if (( total_jobs == 0 )); then
  _err "No jobs found in $CONF"
  echo ""
  echo -e "  ${GRY}Add jobs below the section headers in: ${CYN}$CONF${R}"
  exit 1
fi

# ── --list mode ───────────────────────────────────────────────────────────────

if [[ "$LIST_ONLY" == true ]]; then
  _banner
  _display_jobs
  echo ""
  _dim "${total_jobs} job(s) configured in backups.conf"
  echo ""
  exit 0
fi

# ── --init mode ───────────────────────────────────────────────────────────────

if [[ "$DO_INIT" == true ]]; then
  _init_setup
  exit 0
fi

# ── Interactive job selection ─────────────────────────────────────────────────

_select_jobs

# Build final index list
if (( ${#SELECTED_JOBS[@]} == 0 )); then
  run_indices=()
  for (( i=0; i<total_jobs; i++ )); do run_indices+=("$i"); done
else
  run_indices=( "${SELECTED_JOBS[@]}" )
fi

if (( ${#run_indices[@]} == 0 )); then
  echo ""
  _warn "No valid jobs selected."
  echo ""
  exit 0
fi

# ── Init gate — prompt if any local source dirs are missing ──────────────────

_check_needs_init "${run_indices[@]}"

# ── Auth check for any rclone jobs ────────────────────────────────────────────

needs_rclone=false
for idx in "${run_indices[@]}"; do
  [[ "${JOB_METHODS[$idx]}" == "rclone" ]] && needs_rclone=true && break
done

if [[ "$needs_rclone" == true ]]; then
  _check_rclone_auth || exit 1
fi

# ── Dry-run notice ────────────────────────────────────────────────────────────

if [[ "$DRY_RUN" == true ]]; then
  echo ""
  echo -e "  ${YLW}DRY RUN — no files will be moved or synced${R}"
fi

# ── Run ───────────────────────────────────────────────────────────────────────

echo ""
_hr
echo -e "\n  ${BOLD}Running ${#run_indices[@]} job(s)${R}"
_hr

succeeded=0
failed=0
skipped=0

if [[ "$PARALLEL" == true ]]; then
  pids=()
  for idx in "${run_indices[@]}"; do
    _run_job "$idx" & pids+=("$!")
  done
  for pid in "${pids[@]}"; do
    if wait "$pid"; then (( succeeded++ )) || true
    else                  (( failed++ ))    || true
    fi
  done
else
  for idx in "${run_indices[@]}"; do
    if _run_job "$idx"; then (( succeeded++ )) || true
    else                      (( failed++ ))    || true
    fi
  done
fi

# ── Summary ───────────────────────────────────────────────────────────────────

echo ""
_hr
echo ""
echo -e "  ${BOLD}Summary${R}"
echo ""
(( succeeded > 0 )) && echo -e "  ${GRN}✓${R}  ${succeeded} succeeded"
(( failed    > 0 )) && echo -e "  ${RED}✗${R}  ${failed} failed"
(( skipped   > 0 )) && echo -e "  ${YLW}⚠${R}   ${skipped} skipped"

if [[ "$DRY_RUN" == true ]]; then
  echo ""
  echo -e "  ${YLW}Dry run complete — nothing was modified.${R}"
fi

echo ""
echo -e "  ${GRY}Logs: ${CYN}${LOG_DIR}${R}"
echo ""
