#!/usr/bin/env bash
# isconl-space/bin/isconl
# iSconl personal workspace CLI — the entry point for everything.
# Routes to scope/space/spark/cross-system lib handlers.
#
# Also serves as the backing binary for iscope, ispace, and ispark:
# when called as one of those names (via symlink or wrapper), it
# auto-prepends the matching system so all three entry points share
# a single well-tested binary.
#
# Maintains full backward compatibility with sconlx v1.0.0/v2.x commands.
#
# Usage: isconl [system] [command] [args] [flags]
# Run with no args for the full iSconl dashboard.
#
# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v2.2.0 — Binary renamed from sconlx to isconl. Folder renamed from
#             sconl-space/ to isconl-space/; all internal paths updated.
#             basename dispatch: when invoked as iscope, ispace, or ispark,
#             the matching system is auto-prepended before routing, so each
#             dedicated entry point shares this binary transparently.
#             sconlx retained as a legacy alias command (backward compat for
#             any existing scripts or muscle memory).
#             All help text and error messages updated to use isconl/iscope/
#             ispace/ispark names.
#   v2.0.0 — Full iSconl suite. Scope + Space + Spark + Cross-system.
#             Flat-file mode + SQLite mode. Legacy v1.0.0 commands preserved.
#   v1.0.0 — Initial. Tasks, notes, journal, plan. Flat-file only.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail
IFS=$'\n\t'

# ─────────────────────────────────────────────────────────────────────────────
# CONFIG
# ─────────────────────────────────────────────────────────────────────────────

_ISCONL_VERSION="2.2.0"

# ── Path resolution (symlink-safe, portable) ──────────────────────────────
_readlink_f() {
  local target="$1"
  if readlink -f "$target" &>/dev/null 2>&1; then
    readlink -f "$target"; return
  fi
  if command -v greadlink &>/dev/null; then
    greadlink -f "$target"; return
  fi
  local dir; dir="$(cd "$(dirname "$target")" 2>/dev/null && pwd -P)"
  echo "${dir}/$(basename "$target")"
}

_ISCONL_BIN="$(cd "$(dirname "$(_readlink_f "${BASH_SOURCE[0]}")")" && pwd)"
_ISCONLSPACE_DIR="$(cd "$_ISCONL_BIN/.." && pwd)"
_XSPACE_ROOT="$(cd "$_ISCONLSPACE_DIR/.." && pwd)"
_ISCONLSPACE_LIB_DIR="$_ISCONLSPACE_DIR/lib"
_EQUICYCLE_PY="$_ISCONLSPACE_LIB_DIR/equicycle.py"
_ISCONLSPACE_DATA_DIR="$_ISCONLSPACE_DIR/data"

# ─────────────────────────────────────────────────────────────────────────────
# BASENAME DISPATCH
# When this binary is invoked as iscope, ispace, or ispark (e.g. via a
# symlink or wrapper script), auto-prepend the matching system so the dedicated
# entry points work without any extra routing logic.
# ─────────────────────────────────────────────────────────────────────────────

_INVOKED_AS="$(basename "$0")"
case "$_INVOKED_AS" in
  iscope)  set -- scope  "$@" ;;
  ispace)  set -- space  "$@" ;;
  ispark)  set -- spark  "$@" ;;
  sconlx)  : ;;  # legacy name — route normally, backward compat
esac
unset _INVOKED_AS

# ─────────────────────────────────────────────────────────────────────────────
# BOOTSTRAP — source xspace.conf then all lib modules
# ─────────────────────────────────────────────────────────────────────────────

_XSPACE_CONF="$_XSPACE_ROOT/xspace.conf"
if [[ -f "$_XSPACE_CONF" ]]; then
  source "$_XSPACE_CONF"
fi

for _lib in ui.sh db.sh events.sh scope.sh space.sh spark.sh cross.sh calendar.sh ai.sh; do
  _lib_path="$_ISCONLSPACE_LIB_DIR/$_lib"
  if [[ -f "$_lib_path" ]]; then
    source "$_lib_path"
  else
    printf '  x  Missing lib: %s\n' "$_lib_path" >&2
    exit 1
  fi
done
unset _lib _lib_path

_FLAT_DIR="$_ISCONLSPACE_DATA_DIR"
_db_init || true

# ─────────────────────────────────────────────────────────────────────────────
# HELP
# ─────────────────────────────────────────────────────────────────────────────

_isconl_help() {
  cat >&2 <<HELP

  $(_ui_bold "isconl") v$_ISCONL_VERSION — iSconl personal workspace CLI
  Data mode: $_DATA_MODE

  $(_ui_bold "USAGE")
    isconl [system] [command] [args] [--flags]

  $(_ui_bold "DEDICATED ENTRY POINTS")
    iscope [command]   opens Scope directly  (same as: isconl scope)
    ispace [command]   opens Space directly  (same as: isconl space)
    ispark [command]   opens Spark directly  (same as: isconl spark)

  $(_ui_bold "SYSTEMS")
    $(_ui_scope "scope (s)")   Daily rhythm: inbox, tasks, goals, reflection, cycle
    $(_ui_space "space (sp)")  Domain portfolio: businesses, platforms, projects, hobbies
    $(_ui_spark "spark (k)")   Inner world: journal, ideas, learning, DIA
    x            Cross-system: dashboard, events, search, export
    cal          Calendar: today, upcoming, birthdays, events, history

  $(_ui_bold "SCOPE COMMANDS")     (or: iscope [command])
    iscope                            Scope dashboard
    iscope inbox [add|triage]         Inbox management
    iscope inbox add [text]           Fast capture
    iscope today [add|clear]          Today's tasks
    iscope task [list|add|done|defer|del|show]
    iscope goal [list|add|show|kpi|done]
    iscope reflect [view|history]     Daily reflection
    iscope cycle [list|plan|review]   Cycle management
    iscope identity [edit|north-star|season]
    iscope plan                       Weekly planner

  $(_ui_bold "SPACE COMMANDS")     (or: ispace [command])
    ispace                            Portfolio overview
    ispace list [--active|--type]     List spaces
    ispace show <name|id>             Space detail
    ispace add                        Create space
    ispace review <name|id>           Health review
    ispace review --all               Review all overdue
    ispace project [list|add]
    ispace task [list|add]            Push tasks to Scope
    ispace kpi [log|list|add]
    ispace contact [list|add|interaction]
    ispace event [list|add]
    ispace health                     Portfolio health

  $(_ui_bold "SPARK COMMANDS")     (or: ispark [command])
    ispark                            Spark overview
    ispark journal                    Today's journal (editor)
    ispark journal [view|list|new]
    ispark journal YYYY-MM-DD         Open entry for date
    ispark note [title]               Quick note capture
    ispark idea [list|add|show|develop|advance|export|archive]
    ispark learn [list|add|show|progress|highlight|done|synthesise]
    ispark dia [list|show|overdue|add|log]

  $(_ui_bold "CROSS-SYSTEM")
    isconl x                          Full iSconl dashboard
    isconl x events [process]         Event bus
    isconl x status                   DB + data status
    isconl x search <query>           Search all systems
    isconl x export                   Export all data
    isconl x backup                   Backup via backupx

  $(_ui_bold "CALENDAR")
    isconl cal                        Today's calendar view
    isconl cal upcoming               Upcoming events
    isconl cal birthdays              Birthday tracker
    isconl cal edit                   Edit calendar.json

  $(_ui_bold "LEGACY ALIASES")  (sconlx v1.0.0/v2.x — unchanged)
    sconlx [cmd]          ->  isconl [cmd]
    isconl task [...]     ->  iscope task [...]
    isconl journal        ->  ispark journal
    isconl note [...]     ->  ispark note [...]
    isconl plan           ->  iscope plan

  $(_ui_bold "GLOBAL FLAGS")
    --help, -h          This help text
    --version, -v       Version + data mode
    --status            DB/file status
    --json              JSON output (where supported)
    --no-color          Disable ANSI colors  (or: SCONLX_COLOR=0)
    --dry-run           Show what would happen, write nothing

  $(_ui_bold "ENVIRONMENT")
    EDITOR              Editor for journal/notes (default: nano)
    SCONLX_COLOR=0      Disable color output
    ISCONL_DATA_DIR     Override SQLite data directory

HELP
}

# ─────────────────────────────────────────────────────────────────────────────
# VERSION / STATUS
# ─────────────────────────────────────────────────────────────────────────────

_isconl_version() {
  printf 'isconl %s (%s mode)\n' "$_ISCONL_VERSION" "$_DATA_MODE" >&2
  local data_path="$_ISCONLSPACE_DATA_DIR"
  [[ "$_DATA_MODE" == "sqlite" ]] && data_path="$_ISCONL_DATA_DIR"
  printf 'data: %s\n' "$data_path" >&2
}

_isconl_status() { _cross_status; }

# ─────────────────────────────────────────────────────────────────────────────
# STARTUP — process pending events silently
# ─────────────────────────────────────────────────────────────────────────────

_isconl_startup() {
  local first_arg="${1:-}"
  case "$first_arg" in
    --help|-h|--version|-v|--status|--no-color|--json) return 0 ;;
  esac
  local pending_count; pending_count="$(_ev_status)"
  if [[ "$pending_count" -gt 0 && "$pending_count" -lt 10 ]]; then
    _ev_process_all 2>/dev/null || true
  fi
}

# ─────────────────────────────────────────────────────────────────────────────
# ROUTER
# ─────────────────────────────────────────────────────────────────────────────

_isconl_route() {
  local cmd="${1:-}"
  shift 2>/dev/null || true

  # Global flags
  case "$cmd" in
    --help|-h)     _isconl_help; return 0 ;;
    --version|-v)  _isconl_version; return 0 ;;
    --status)      _isconl_status; return 0 ;;
    --no-color)    _UI_COLOR=0; cmd="${1:-}"; shift 2>/dev/null || true ;;
    --json)        _SCONLX_JSON=1; cmd="${1:-}"; shift 2>/dev/null || true ;;
    --dry-run)     _SCONLX_DRY_RUN=1; cmd="${1:-}"; shift 2>/dev/null || true ;;
  esac

  case "${cmd:-dashboard}" in
    # Primary systems
    scope|s)         _scope_route "$@" ;;
    space|sp)        _space_route "$@" ;;
    spark|k)         _spark_route "$@" ;;
    x|cross)         _cross_route "$@" ;;
    cal|calendar)    _cal_route "$@" ;;

    # Legacy v1.0.0 / v2.x aliases — all preserved unchanged
    task)            _scope_route task "$@" ;;
    journal)         _spark_route journal "$@" ;;
    note)            _spark_route note "$@" ;;
    plan)            _scope_route plan "$@" ;;

    # Dashboard
    ""|dashboard)    _cross_dashboard ;;

    *)
      _ui_err "Unknown command: $cmd" >&2
      printf '\n  Run: isconl --help  for all commands\n\n' >&2
      return 1
      ;;
  esac
}

# ─────────────────────────────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────────────────────────────

_isconl_startup "$@" || true
_isconl_route "$@" || true
