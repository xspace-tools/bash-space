#!/usr/bin/env bash
# isconl-space/bin/ispace
#
# iSpace — dedicated Space entry point.
# Domain portfolio: businesses, platforms, projects, hobbies, contacts, KPIs.
#
# Thin wrapper backed by the isconl binary. isconl's basename dispatch
# auto-prepends 'space' when invoked under this name.
#
# Usage:
#   ispace                        Portfolio overview
#   ispace list [--active|--type] List all spaces
#   ispace show <name|id>         Space detail
#   ispace add                    Create space
#   ispace review <name|id>       Health review
#   ispace review --all           Review all overdue spaces
#   ispace project [list|add]     Projects within a space
#   ispace task [list|add]        Tasks (pushed to Scope)
#   ispace kpi [log|list|add]     KPI tracking
#   ispace contact [list|add|interaction]
#   ispace event [list|add]       Event log
#   ispace health                 Portfolio health summary
#   ispace --help                 Full Space help
#
# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v1.0.0 — Initial. Dedicated Space entry point backed by isconl binary.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

_readlink_f() {
  local target="$1"
  if readlink -f "$target" &>/dev/null 2>&1; then
    readlink -f "$target"; return
  fi
  if command -v greadlink &>/dev/null; then
    greadlink -f "$target"; return
  fi
  local dir; dir="$(cd "$(dirname "$target")" 2>/dev/null && pwd -P)"
  echo "${dir}/$(basename "$target")"
}

_BIN_DIR="$(cd "$(dirname "$(_readlink_f "${BASH_SOURCE[0]}")")" && pwd)"
_ISCONL="$_BIN_DIR/isconl"

if [[ ! -f "$_ISCONL" ]]; then
  printf '  x  isconl not found at %s\n' "$_ISCONL" >&2
  printf '     Reinstall: installx\n' >&2
  exit 1
fi

exec "$_ISCONL" space "$@"
