#!/usr/bin/env bash
# isconl-space/bin/iscope
#
# iScope — dedicated Scope entry point.
# Daily rhythm: inbox, tasks, goals, reflection, cycle planning.
#
# This is a thin wrapper that resolves the isconl binary and invokes it
# as 'iscope'. isconl's basename dispatch auto-prepends the 'scope' system
# when invoked under this name, so all routing, lib loading, and data handling
# are handled in one place.
#
# Usage:
#   iscope                       Scope dashboard
#   iscope inbox [add|triage]    Inbox management
#   iscope inbox add [text]      Fast capture
#   iscope today [add|clear]     Today's tasks
#   iscope task [list|add|done|defer|del|show]
#   iscope goal [list|add|show|kpi|done]
#   iscope reflect [view|history]
#   iscope cycle [list|plan|review]
#   iscope identity [edit|north-star|season]
#   iscope plan                  Weekly planner
#   iscope --help                Full Scope help
#
# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v1.0.0 — Initial. Dedicated Scope entry point backed by isconl binary.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

_readlink_f() {
  local target="$1"
  if readlink -f "$target" &>/dev/null 2>&1; then
    readlink -f "$target"; return
  fi
  if command -v greadlink &>/dev/null; then
    greadlink -f "$target"; return
  fi
  local dir; dir="$(cd "$(dirname "$target")" 2>/dev/null && pwd -P)"
  echo "${dir}/$(basename "$target")"
}

_BIN_DIR="$(cd "$(dirname "$(_readlink_f "${BASH_SOURCE[0]}")")" && pwd)"
_ISCONL="$_BIN_DIR/isconl"

if [[ ! -f "$_ISCONL" ]]; then
  printf '  x  isconl not found at %s\n' "$_ISCONL" >&2
  printf '     Reinstall: installx\n' >&2
  exit 1
fi

# exec replaces this process — no overhead, no extra PID.
# isconl sees argv[0] as 'iscope' via basename dispatch and prepends 'scope'.
exec "$_ISCONL" scope "$@"
