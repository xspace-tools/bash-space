#!/usr/bin/env bash
# sys-space/bin/refreshx
#
# Reload shell config and clear the command hash cache.
# Run after _configure/install.sh or after adding scripts to any space's bin/.

# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v0.2.0 — Fixed BASHRCSOURCED unbound variable crash on Fedora. Root cause:
#             set -euo pipefail was active when ~/.bashrc was sourced, which
#             chains into /etc/bashrc. Fedora's /etc/bashrc references
#             BASHRCSOURCED before it's set — that fails under -u (nounset).
#             Fix: removed set -euo pipefail. Not appropriate for a script
#             that sources user shell config.
#   v0.1.0 — Initial release.
# ─────────────────────────────────────────────────────────────────────────────

# NOTE: no "set -euo pipefail" — see changelog above.

# ─────────────────────────────────────────────────────────────────────────────
# CONFIG
# ─────────────────────────────────────────────────────────────────────────────

_BASH_RC="$HOME/.bashrc"
_ZSH_RC="$HOME/.zshrc"

# ─────────────────────────────────────────────────────────────────────────────
# HELP
# ─────────────────────────────────────────────────────────────────────────────

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat <<'HELP'

  refreshx — reload shell config and clear command cache

  USAGE
    refreshx

  Sources ~/.bashrc (bash) or ~/.zshrc (zsh), then runs hash -r.
  Run after install or after adding new scripts to any space's bin/.

HELP
    exit 0
fi

# ─────────────────────────────────────────────────────────────────────────────
# RELOAD
# ─────────────────────────────────────────────────────────────────────────────

if [[ -n "${BASH_VERSION-}" ]]; then
    # shellcheck source=/dev/null
    source "$_BASH_RC"
    hash -r
    echo "Shell refreshed (bash)"
elif [[ -n "${ZSH_VERSION-}" ]]; then
    # shellcheck source=/dev/null
    source "$_ZSH_RC"
    hash -r
    echo "Shell refreshed (zsh)"
else
    echo "refreshx: unknown shell — please reload manually"
    exit 1
fi
