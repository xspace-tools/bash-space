#!/usr/bin/env bash
# server-space/bin/serverx
#
# Launch, connect to, and manage the server-space Ubuntu VM.
# Always shows `virsh list --all` at the top of every run.
#
# Usage:
#   serverx            start VM → get IP → SSH in → prompt to shutdown on exit
#   serverx --stop     gracefully shutdown the VM
#   serverx --status   show VM status and IP only
#   serverx --ip       print VM IP address only
#   serverx --help

# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v1.0.0 — Initial release. Start/stop/status/SSH flow. Auto IP detection
#             with retry backoff. Always shows virsh list --all on entry.
#             Shutdown prompt on SSH exit. Graceful sudo handling.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail
IFS=$'\n\t'

# ─────────────────────────────────────────────────────────────────────────────
# CONFIG
# ─────────────────────────────────────────────────────────────────────────────

VM_NAME="server-space"
VM_USER="sconl"
VM_SSH_PORT="22"

# IP detection: seconds to wait for VM to boot and get a DHCP lease
IP_WAIT_TOTAL=60
IP_WAIT_INTERVAL=3

# ─────────────────────────────────────────────────────────────────────────────
# COLORS
# ─────────────────────────────────────────────────────────────────────────────

if [[ -t 1 && "${NO_COLOR:-}" != "1" ]]; then
  R=$'\033[0m'      BOLD=$'\033[1m'    DIM=$'\033[2m'
  GRN=$'\033[0;32m' YLW=$'\033[0;33m' BLU=$'\033[0;34m'
  CYN=$'\033[0;36m' RED=$'\033[0;31m' WHT=$'\033[1;37m'
  GRY=$'\033[0;90m'
else
  R='' BOLD='' DIM='' GRN='' YLW='' BLU='' CYN='' RED='' WHT='' GRY=''
fi

_ok()   { echo -e "  ${GRN}✓${R}  $*"; }
_info() { echo -e "  ${BLU}›${R}  $*"; }
_warn() { echo -e "  ${YLW}⚠${R}   $*"; }
_err()  { echo -e "  ${RED}✗${R}  $*" >&2; }
_dim()  { echo -e "     ${GRY}$*${R}"; }
_hr()   { echo -e "\n  ${DIM}────────────────────────────────────────────────────────${R}"; }

# ─────────────────────────────────────────────────────────────────────────────
# HELPERS
# ─────────────────────────────────────────────────────────────────────────────

# Always show all VMs — called at the top of every execution path
_show_vm_list() {
  echo ""
  echo -e "  ${BOLD}${WHT}Virtual Machines${R}"
  _hr
  echo ""
  sudo virsh list --all 2>/dev/null | while IFS= read -r line; do
    if echo "$line" | grep -q "running"; then
      echo -e "  ${GRN}${line}${R}"
    elif echo "$line" | grep -q "shut off"; then
      echo -e "  ${GRY}${line}${R}"
    else
      echo -e "  ${DIM}${line}${R}"
    fi
  done
  echo ""
}

_vm_state() {
  sudo virsh domstate "$VM_NAME" 2>/dev/null | tr -d ' \n' || echo "unknown"
}

# Try two methods to get the IP: domifaddr (requires guest agent or ARP), then
# fall back to parsing ARP table. Returns empty string if not found.
_get_ip() {
  local ip=""

  # Method 1: guest agent (most reliable — needs qemu-guest-agent inside VM)
  ip="$(sudo virsh domifaddr "$VM_NAME" --source agent 2>/dev/null \
    | awk '/ipv4/ { split($4, a, "/"); print a[1]; exit }' || true)"
  [[ -n "$ip" ]] && { echo "$ip"; return; }

  # Method 2: lease table (works with NAT/default network)
  ip="$(sudo virsh domifaddr "$VM_NAME" 2>/dev/null \
    | awk '/ipv4/ { split($4, a, "/"); print a[1]; exit }' || true)"
  [[ -n "$ip" ]] && { echo "$ip"; return; }

  # Method 3: ARP scan for libvirt MAC
  local mac
  mac="$(sudo virsh domiflist "$VM_NAME" 2>/dev/null \
    | awk 'NR>2 && $5 != "-" { print $5; exit }' || true)"
  if [[ -n "$mac" ]]; then
    ip="$(arp -n 2>/dev/null | awk -v m="$mac" 'tolower($0) ~ tolower(m) { print $1; exit }' || true)"
    [[ -n "$ip" ]] && { echo "$ip"; return; }
  fi

  echo ""
}

# Poll for IP until found or timeout
_wait_for_ip() {
  local elapsed=0
  local ip=""
  _info "Waiting for VM to get IP address..."
  while (( elapsed < IP_WAIT_TOTAL )); do
    ip="$(_get_ip)"
    if [[ -n "$ip" ]]; then
      echo "$ip"
      return 0
    fi
    sleep "$IP_WAIT_INTERVAL"
    (( elapsed += IP_WAIT_INTERVAL )) || true
    printf "  ${GRY}.${R}"
  done
  echo ""
  printf "\n"
  return 1
}

# ─────────────────────────────────────────────────────────────────────────────
# FLAGS
# ─────────────────────────────────────────────────────────────────────────────

MODE="connect"  # default

while [[ $# -gt 0 ]]; do
  case "$1" in
    --stop)   MODE="stop";   shift ;;
    --status) MODE="status"; shift ;;
    --ip)     MODE="ip";     shift ;;
    --help|-h)
      cat <<EOF

  ${BOLD}serverx${R} — server-space VM manager

  ${BOLD}USAGE${R}
    serverx            start VM → SSH in (default)
    serverx --stop     gracefully shut down the VM
    serverx --status   show VM status and current IP
    serverx --ip       print the VM IP address only
    serverx --help

  ${BOLD}VM${R}
    Name : ${VM_NAME}
    User : ${VM_USER}
    SSH  : ${VM_USER}@<ip>

  ${BOLD}FIRST TIME${R}
    1. Ensure server-space VM is defined in virsh
    2. Install qemu-guest-agent inside VM for reliable IP detection:
       sudo apt install qemu-guest-agent
    3. Optional: configure static IP in VM for consistent SSH

EOF
      exit 0
      ;;
    *) _err "Unknown flag: $1"; exit 1 ;;
  esac
done

# ─────────────────────────────────────────────────────────────────────────────
# BANNER
# ─────────────────────────────────────────────────────────────────────────────

echo ""
echo -e "  ${BOLD}${WHT}serverx${R}${GRY} — server-space VM${R}"

_show_vm_list

# ─────────────────────────────────────────────────────────────────────────────
# MODE: STATUS
# ─────────────────────────────────────────────────────────────────────────────

if [[ "$MODE" == "status" ]]; then
  state="$(_vm_state)"
  echo -e "  ${GRY}VM     ${CYN}${VM_NAME}${R}"
  echo -e "  ${GRY}State  ${R}${state}"
  if [[ "$state" == "running" ]]; then
    ip="$(_get_ip)"
    if [[ -n "$ip" ]]; then
      echo -e "  ${GRY}IP     ${CYN}${ip}${R}"
      echo -e "  ${GRY}SSH    ${R}ssh ${VM_USER}@${ip}"
    else
      echo -e "  ${GRY}IP     ${YLW}not yet available${R}"
    fi
  fi
  echo ""
  exit 0
fi

# ─────────────────────────────────────────────────────────────────────────────
# MODE: IP
# ─────────────────────────────────────────────────────────────────────────────

if [[ "$MODE" == "ip" ]]; then
  state="$(_vm_state)"
  if [[ "$state" != "running" ]]; then
    _err "VM is not running (state: $state)"
    exit 1
  fi
  ip="$(_get_ip)"
  if [[ -n "$ip" ]]; then
    echo "$ip"
  else
    _err "Could not determine VM IP address"
    exit 1
  fi
  exit 0
fi

# ─────────────────────────────────────────────────────────────────────────────
# MODE: STOP
# ─────────────────────────────────────────────────────────────────────────────

if [[ "$MODE" == "stop" ]]; then
  state="$(_vm_state)"
  if [[ "$state" == "shut off" ]]; then
    _ok "VM is already shut off."
    echo ""
    exit 0
  fi
  _info "Shutting down ${VM_NAME}..."
  sudo virsh shutdown "$VM_NAME"
  _ok "Shutdown signal sent. VM will stop shortly."
  echo ""
  exit 0
fi

# ─────────────────────────────────────────────────────────────────────────────
# MODE: CONNECT (default — start + SSH)
# ─────────────────────────────────────────────────────────────────────────────

state="$(_vm_state)"

case "$state" in
  "running")
    _ok "VM is already running."
    ;;
  "shut off" | "")
    _info "Starting ${VM_NAME}..."
    sudo virsh start "$VM_NAME"
    _ok "VM started."
    ;;
  "paused")
    _info "Resuming ${VM_NAME}..."
    sudo virsh resume "$VM_NAME"
    _ok "VM resumed."
    ;;
  *)
    _warn "Unexpected VM state: '${state}' — attempting to start anyway..."
    sudo virsh start "$VM_NAME" || true
    ;;
esac

# Get IP
echo ""
ip="$(_wait_for_ip)"
echo ""

if [[ -z "$ip" ]]; then
  _warn "Could not detect IP automatically after ${IP_WAIT_TOTAL}s."
  echo ""
  printf "  ${CYN}Enter VM IP manually:${R} "
  read -r ip
  ip="${ip//[[:space:]]/}"
  if [[ -z "$ip" ]]; then
    _err "No IP provided. Aborting."
    echo -e "  ${GRY}Try:  virsh domifaddr ${VM_NAME}${R}"
    echo ""
    exit 1
  fi
fi

echo ""
_ok "IP: ${CYN}${ip}${R}"
_dim "Connecting: ssh ${VM_USER}@${ip}"
echo ""
_hr
echo ""

# SSH — pass through without capturing exit code; prompt to shutdown after
ssh -o StrictHostKeyChecking=accept-new \
    -o ConnectTimeout=10 \
    -p "$VM_SSH_PORT" \
    "${VM_USER}@${ip}" || true

# Post-SSH: offer to shut down VM
echo ""
_hr
echo ""
echo -e "  ${BOLD}Session ended.${R}"
echo ""
printf "  ${CYN}Shut down ${VM_NAME}?${R} ${GRY}[Y/n]:${R} "
read -r _shutdown
if [[ -z "${_shutdown:-}" || "${_shutdown,,}" =~ ^y ]]; then
  sudo virsh shutdown "$VM_NAME"
  _ok "Shutdown signal sent."
fi

echo ""
