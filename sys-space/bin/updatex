#!/usr/bin/env bash
# sys-space/bin/updatex
#
# System + XSpace repo + Flutter/Dart/Firebase updater.
# Works on Linux (Fedora, Debian/Ubuntu, Arch), macOS, and Windows (Git Bash).
#
# Usage:
#   updatex              system packages + xspace repo + flutter (default)
#   updatex --system     system packages only
#   updatex --xspace     xspace repo only
#   updatex --flutter    Flutter SDK + Dart globals + Firebase CLI only
#   updatex --skip-pull  run install.sh only, no git pull
#   updatex --help

# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v0.5.0 — Added --flutter flag and Flutter update step. Included in the
#             default run alongside system + xspace. Flutter update covers:
#               flutter upgrade  (SDK to latest stable)
#               flutter pub cache repair  (if cache is stale)
#               dart pub global activate firebase_cli  (Dart Firebase CLI)
#               npm install -g firebase-tools  (npm Firebase CLI — whichever
#                 is detected, matching FIREBASE_CLI_SOURCE in xspace.conf)
#               dart pub global activate flutterfire_cli
#               dart pub global activate devtools  (Flutter DevTools)
#             Each tool is only upgraded if it is already installed — nothing
#             is installed for the first time here (use installx for that).
#             FIREBASE_CLI_SOURCE in xspace.conf controls which Firebase CLI
#             variant is upgraded (npm or dart).
#   v0.4.0 — Fixed UPDATE_SCRIPT path (now in _configure/lib/). Full OS support:
#             Fedora, Debian/Ubuntu, Arch, macOS (softwareupdate + brew + mas),
#             Windows (winget / choco). Removed unicode symbols.
#   v0.3.0 — Fixed XSPACE_ROOT resolution. Added --help/--system/--xspace flags.
#   v0.2.0 — XSPACE_ROOT auto-detected. --skip-pull flag added.
#   v0.1.0 — Initial release.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail
IFS=$'\n\t'

# ─────────────────────────────────────────────────────────────────────────────
# BOOTSTRAP
# This script lives at: xspace/sys-space/bin/updatex
# XSPACE_ROOT is:       xspace/
# Path:                 bin/ -> sys-space/ -> xspace/  (two levels up)
# ─────────────────────────────────────────────────────────────────────────────

_readlink_f() {
  local target="$1"
  if readlink -f "$target" &>/dev/null 2>&1; then
    readlink -f "$target"; return
  fi
  if command -v greadlink &>/dev/null; then
    greadlink -f "$target"; return
  fi
  local dir; dir="$(cd "$(dirname "$target")" 2>/dev/null && pwd -P)"
  echo "${dir}/$(basename "$target")"
}

_SELF_BIN="$(cd "$(dirname "$(_readlink_f "${BASH_SOURCE[0]}")")" && pwd)"
XSPACE_ROOT="$(cd "$_SELF_BIN/../.." && pwd)"

CONF="$XSPACE_ROOT/xspace.conf"
if [[ ! -f "$CONF" ]]; then
  echo ""
  echo "  x  xspace.conf not found at $CONF"
  echo "  Expected at the monorepo root: $XSPACE_ROOT/xspace.conf"
  echo ""
  exit 1
fi
source "$CONF"

# ─────────────────────────────────────────────────────────────────────────────
# OS DETECTION
# ─────────────────────────────────────────────────────────────────────────────

_detect_os() {
  case "$(uname -s 2>/dev/null)" in
    Linux*)               echo "linux"   ;;
    Darwin*)              echo "mac"     ;;
    MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
    *)                    echo "unknown" ;;
  esac
}
OS="$(_detect_os)"

# ─────────────────────────────────────────────────────────────────────────────
# COLORS
# ─────────────────────────────────────────────────────────────────────────────

if [[ -t 1 && "${NO_COLOR:-}" != "1" ]]; then
  R=$'\033[0m'      BOLD=$'\033[1m'    DIM=$'\033[2m'
  GRN=$'\033[0;32m' YLW=$'\033[0;33m' CYN=$'\033[0;36m'
  RED=$'\033[0;31m' WHT=$'\033[1;37m' GRY=$'\033[0;90m'
else
  R='' BOLD='' DIM='' GRN='' YLW='' CYN='' RED='' WHT='' GRY=''
fi

ok()   { echo -e "  ${GRN}+${R}    $*"; }
warn() { echo -e "  ${YLW}!${R}    $*"; }
err()  { echo -e "  ${RED}x${R}    $*" >&2; }
info() { echo -e "  ${CYN}>  ${R}$*"; }
hr()   { echo ""; echo -e "  ${DIM}-- $* --------------------------------------------------${R}"; }

# ─────────────────────────────────────────────────────────────────────────────
# FLAGS
# ─────────────────────────────────────────────────────────────────────────────

DO_SYSTEM=true
DO_XSPACE=true
DO_FLUTTER=true
SKIP_PULL=false

# If the user passes any specific flag, run only that scope.
# --flutter alone means just flutter. etc.
_EXPLICIT=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --system)
      [[ "$_EXPLICIT" == false ]] && { DO_SYSTEM=true; DO_XSPACE=false; DO_FLUTTER=false; }
      DO_SYSTEM=true; _EXPLICIT=true; shift ;;
    --xspace)
      [[ "$_EXPLICIT" == false ]] && { DO_SYSTEM=false; DO_XSPACE=true; DO_FLUTTER=false; }
      DO_XSPACE=true; _EXPLICIT=true; shift ;;
    --flutter)
      [[ "$_EXPLICIT" == false ]] && { DO_SYSTEM=false; DO_XSPACE=false; DO_FLUTTER=true; }
      DO_FLUTTER=true; _EXPLICIT=true; shift ;;
    --skip-pull)  SKIP_PULL=true; shift ;;
    --help|-h)
      cat <<EOF

  ${BOLD}updatex${R} v0.5.0 — system + XSpace + Flutter updater

  ${BOLD}USAGE${R}
    updatex              system + xspace + flutter  (all three, default)
    updatex --system     system packages only
    updatex --xspace     xspace repo only
    updatex --flutter    Flutter/Dart/Firebase only
    updatex --skip-pull  re-run install.sh without git pull
    updatex --help

  ${BOLD}SYSTEM  (OS-aware)${R}
    Linux (Fedora)  : dnf upgrade -> flatpak update -> dnf autoremove
    Linux (apt)     : apt update + upgrade + autoremove
    Linux (Arch)    : pacman -Syu
    macOS           : softwareupdate -ia -> brew update + upgrade + autoremove
                      mas upgrade (if mas installed — Mac App Store)
    Windows         : winget upgrade --all  or  choco upgrade all

  ${BOLD}XSPACE${R}
    git pull --ff-only origin main  ->  _configure/lib/install.sh

  ${BOLD}FLUTTER${R}  (only upgrades tools already installed — won't install new ones)
    flutter upgrade              Flutter SDK to latest stable
    flutter pub cache repair     repair pub cache if stale
    dart pub global activate     firebase_cli  (if dart variant in use)
    npm install -g firebase-tools              (if npm variant in use)
    dart pub global activate     flutterfire_cli
    dart pub global activate     devtools

  ${BOLD}FIREBASE_CLI_SOURCE${R} in xspace.conf controls which Firebase CLI is upgraded.
    npm   (default)  — npm install -g firebase-tools
    dart             — dart pub global activate firebase_cli

EOF
      exit 0
      ;;
    *) warn "Unknown flag: $1 — try --help"; exit 1 ;;
  esac
done

# ─────────────────────────────────────────────────────────────────────────────
# VALIDATE — update.sh path
# Supports both _configure/lib/update.sh (new) and _configure/update.sh (old)
# ─────────────────────────────────────────────────────────────────────────────

_CONFIGURE_ROOT="$XSPACE_ROOT/${CONFIGURE_DIR:-_configure}"
UPDATE_SCRIPT=""
for _candidate in \
    "$_CONFIGURE_ROOT/lib/update.sh" \
    "$_CONFIGURE_ROOT/update.sh"; do
  if [[ -f "$_candidate" ]]; then
    UPDATE_SCRIPT="$_candidate"
    break
  fi
done

if [[ "$DO_XSPACE" == true && -z "$UPDATE_SCRIPT" ]]; then
  err "Orchestrator update script not found."
  echo -e "  ${GRY}Searched:${R}"
  echo -e "  ${GRY}  ${CYN}${_CONFIGURE_ROOT}/lib/update.sh${R}"
  echo -e "  ${GRY}  ${CYN}${_CONFIGURE_ROOT}/update.sh${R}"
  echo ""
  echo -e "  ${GRY}CONFIGURE_DIR : ${CYN}${CONFIGURE_DIR:-_configure}${R}  ${GRY}(from xspace.conf)${R}"
  echo -e "  ${GRY}XSPACE_ROOT   : ${CYN}${XSPACE_ROOT}${R}"
  exit 1
fi

# ─────────────────────────────────────────────────────────────────────────────
# HEADER
# ─────────────────────────────────────────────────────────────────────────────

echo ""
echo -e "  ${BOLD}${WHT}updatex${R}${GRY} v0.5.0 — system + XSpace + Flutter updater${R}"
echo -e "  ${GRY}root : ${CYN}${XSPACE_ROOT}${R}"
echo -e "  ${GRY}os   : ${CYN}${OS}${R}"
echo -e "  ${GRY}scope: ${CYN}$( \
  parts=(); \
  [[ "$DO_SYSTEM" == true ]]  && parts+=("system"); \
  [[ "$DO_XSPACE" == true ]]  && parts+=("xspace"); \
  [[ "$DO_FLUTTER" == true ]] && parts+=("flutter"); \
  IFS='+'; printf '%s' "${parts[*]}"
)${R}"

# ─────────────────────────────────────────────────────────────────────────────
# SYSTEM UPDATE
# ─────────────────────────────────────────────────────────────────────────────

if [[ "$DO_SYSTEM" == true ]]; then
  hr "System packages  ($OS)"

  case "$OS" in
    linux)
      if command -v dnf &>/dev/null; then
        info "dnf upgrade..."
        sudo dnf upgrade -y
        ok "dnf upgrade complete"
        if command -v flatpak &>/dev/null; then
          info "flatpak update..."
          flatpak update -y
          ok "flatpak update complete"
        fi
        info "dnf autoremove..."
        sudo dnf autoremove -y
        ok "dnf autoremove complete"

      elif command -v apt &>/dev/null; then
        info "apt update..."
        sudo apt update
        info "apt upgrade..."
        sudo apt upgrade -y
        info "apt autoremove..."
        sudo apt autoremove -y
        ok "apt upgrade complete"

      elif command -v pacman &>/dev/null; then
        info "pacman -Syu..."
        sudo pacman -Syu --noconfirm
        ok "pacman upgrade complete"

      else
        warn "No supported package manager found (dnf / apt / pacman)"
      fi
      ;;

    mac)
      info "macOS software update..."
      sudo softwareupdate -ia --verbose 2>&1 \
        | grep -E '(Installing|No new software|Error)' || true
      ok "macOS software update complete"

      if command -v brew &>/dev/null; then
        info "brew update..."
        brew update
        info "brew upgrade..."
        brew upgrade
        info "brew autoremove + cleanup..."
        brew autoremove
        brew cleanup
        ok "Homebrew upgrade complete"
      else
        warn "Homebrew not found — install from https://brew.sh"
      fi

      if command -v mas &>/dev/null; then
        info "mas upgrade  (Mac App Store)..."
        mas upgrade
        ok "Mac App Store upgrade complete"
      fi
      ;;

    windows)
      if command -v winget &>/dev/null; then
        info "winget upgrade --all..."
        winget upgrade --all --silent --accept-source-agreements \
          --accept-package-agreements || true
        ok "winget upgrade complete"
      elif command -v choco &>/dev/null; then
        info "choco upgrade all..."
        choco upgrade all -y
        ok "choco upgrade complete"
      else
        warn "No supported package manager found (winget / choco)"
        warn "Install winget: https://aka.ms/getwinget"
      fi
      ;;

    *) warn "Unknown OS — skipping system update." ;;
  esac
fi

# ─────────────────────────────────────────────────────────────────────────────
# XSPACE UPDATE
# ─────────────────────────────────────────────────────────────────────────────

if [[ "$DO_XSPACE" == true ]]; then
  hr "XSpace repo update"
  echo -e "  ${GRY}root: ${CYN}${XSPACE_ROOT}${R}"
  echo ""

  if [[ "$SKIP_PULL" == false ]]; then
    info "git pull --ff-only origin main..."
    cd "$XSPACE_ROOT"
    if git pull --ff-only origin main; then
      ok "Repository up to date"
    else
      warn "git pull failed — check remote and branch name."
      warn "Re-run with --skip-pull to just re-run install.sh."
      exit 1
    fi
    echo ""
  else
    info "Skipping git pull  (--skip-pull)"
  fi

  info "Re-running install.sh..."
  echo ""
  # --no-pause: install.sh pause is skipped; updatex pauses once at the end
  "$UPDATE_SCRIPT" --skip-pull --no-pause
fi

# ─────────────────────────────────────────────────────────────────────────────
# FLUTTER / DART / FIREBASE UPDATE
# Only upgrades tools that are already installed. Never installs new tools.
# Use installx (or manual install) to add new tools for the first time.
# ─────────────────────────────────────────────────────────────────────────────

if [[ "$DO_FLUTTER" == true ]]; then
  hr "Flutter / Dart / Firebase tooling"

  # ── Flutter SDK ──────────────────────────────────────────────────────────
  if command -v flutter &>/dev/null; then
    info "flutter upgrade  (SDK to latest stable)..."
    flutter upgrade --force
    ok "flutter upgraded: $(flutter --version 2>/dev/null | awk 'NR==1{print $2}')"

    # Repair pub cache if needed (common after SDK upgrade)
    info "flutter pub cache repair..."
    flutter pub cache repair
    ok "pub cache repair complete"
  else
    warn "flutter not found — skipping SDK upgrade"
    warn "Install: https://docs.flutter.dev/get-started/install"
  fi

  # ── Firebase CLI ──────────────────────────────────────────────────────────
  # Upgrade whichever variant is configured in xspace.conf (npm default).
  # If both are installed, upgrade both.
  _firebase_source="${FIREBASE_CLI_SOURCE:-npm}"
  _upgraded_firebase=false

  if [[ "$_firebase_source" == "npm" ]] || command -v firebase &>/dev/null; then
    if command -v npm &>/dev/null && command -v firebase &>/dev/null; then
      info "npm install -g firebase-tools  (upgrading Firebase CLI)..."
      npm install -g firebase-tools
      ok "firebase-tools upgraded: $(firebase --version 2>/dev/null || echo 'check manually')"
      _upgraded_firebase=true
    elif command -v npm &>/dev/null && [[ "$_firebase_source" == "npm" ]]; then
      info "npm install -g firebase-tools  (installing Firebase CLI)..."
      npm install -g firebase-tools
      ok "firebase-tools installed"
      _upgraded_firebase=true
    fi
  fi

  if [[ "$_firebase_source" == "dart" ]] && command -v dart &>/dev/null; then
    info "dart pub global activate firebase_cli..."
    dart pub global activate firebase_cli
    ok "firebase_cli (dart) upgraded"
    _upgraded_firebase=true
  fi

  if [[ "$_upgraded_firebase" == false ]]; then
    warn "Firebase CLI not upgraded — neither npm+firebase nor dart found"
    warn "Install: npm install -g firebase-tools  (requires Node.js)"
  fi

  # ── FlutterFire CLI ───────────────────────────────────────────────────────
  if command -v dart &>/dev/null; then
    info "dart pub global activate flutterfire_cli..."
    dart pub global activate flutterfire_cli
    if command -v flutterfire &>/dev/null; then
      ok "flutterfire_cli upgraded"
    else
      ok "flutterfire_cli installed — open a new terminal for it to appear on PATH"
    fi
  else
    warn "dart not found — skipping flutterfire_cli upgrade"
  fi

  # ── Dart DevTools ─────────────────────────────────────────────────────────
  if command -v dart &>/dev/null; then
    info "dart pub global activate devtools..."
    dart pub global activate devtools
    ok "devtools upgraded"
  fi

  # ── Dart pub global summary ───────────────────────────────────────────────
  if command -v dart &>/dev/null; then
    echo ""
    echo -e "  ${GRY}Dart pub global packages:${R}"
    dart pub global list 2>/dev/null | while IFS= read -r line; do
      echo -e "     ${GRY}${line}${R}"
    done
  fi

  # ── PATH reminder ─────────────────────────────────────────────────────────
  _pub_bin="${DART_PUB_GLOBAL_DIR:-$HOME/.pub-cache}/bin"
  if [[ ":$PATH:" != *":${_pub_bin}:"* ]]; then
    echo ""
    warn "~/.pub-cache/bin is not on PATH in this session"
    warn "Open a new terminal or run:  source ~/.bashrc"
    warn "installx adds this automatically on fresh installs"
  fi
fi

# ─────────────────────────────────────────────────────────────────────────────
# DONE
# ─────────────────────────────────────────────────────────────────────────────

echo ""
hr "Done"
echo ""
ok "All updates complete."
echo ""
echo -e "  ${GRY}Open a new terminal or run ${CYN}refreshx${R}${GRY} to activate any PATH changes.${R}"
echo ""
