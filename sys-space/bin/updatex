#!/usr/bin/env bash
# sys-space/bin/updatex
#
# Workstation system updater + XSpace repo updater.
# Runs dnf upgrade, flatpak update, dnf autoremove, then optionally
# pulls the latest xspace repo and re-runs install.sh.
#
# Workstation-specific — uses dnf (Fedora). Adapt lib/sysupdate.sh for
# other distros when that abstraction is needed.

# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v0.2.0 — Fixed broken path: was hardcoded to x-space/update.sh.
#             Now reads CONFIGURE_DIR from xspace.conf so any future rename
#             of the orchestrator folder only needs one conf edit.
#   v0.1.0 — Initial release in sys-space/bin/.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# BOOTSTRAP
# ─────────────────────────────────────────────────────────────────────────────
# SPACE_DIR  = sys-space/    (one up from bin/)
# XSPACE_ROOT = xspace/       (one further up — where xspace.conf lives)

_REAL_BIN="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
SPACE_DIR="$(cd "$_REAL_BIN/.." && pwd)"
XSPACE_ROOT="$(cd "$SPACE_DIR/.." && pwd)"

# Source xspace.conf to get CONFIGURE_DIR — never hardcode "_configure"
CONF="$XSPACE_ROOT/xspace.conf"
if [[ ! -f "$CONF" ]]; then
    echo "updatex: xspace.conf not found at $CONF"
    echo "         Re-run _configure/install.sh"
    exit 1
fi
source "$CONF"

# ─────────────────────────────────────────────────────────────────────────────
# CONFIG
# ─────────────────────────────────────────────────────────────────────────────

# CONFIGURE_DIR is set by xspace.conf (currently "_configure")
_UPDATE_SCRIPT="$XSPACE_ROOT/$CONFIGURE_DIR/update.sh"

ok()   { echo "  ✓ $*"; }
warn() { echo "  ⚠  $*"; }
log()  { echo "  → $*"; }
hr()   { echo ""; echo "  ── $* ──────────────────────────────────────────────────"; }

# ─────────────────────────────────────────────────────────────────────────────
# HELP
# ─────────────────────────────────────────────────────────────────────────────

usage() {
    cat <<'HELP'

  updatex — system + XSpace updater

  USAGE
    updatex                  system update AND xspace repo update (default)
    updatex --system         system packages only (dnf + flatpak)
    updatex --xspace         xspace repo only (git pull + install.sh)
    updatex --skip-pull      xspace install.sh only, no git pull
    updatex --help

  System update steps:
    1. sudo dnf upgrade --refresh
    2. flatpak update
    3. sudo dnf autoremove

  XSpace update steps:
    1. git pull --ff-only origin main (from xspace repo root)
    2. _configure/install.sh (re-wires all symlinks and PATH entries)

HELP
}

# ─────────────────────────────────────────────────────────────────────────────
# PARSE ARGS
# ─────────────────────────────────────────────────────────────────────────────

RUN_SYSTEM=true
RUN_XSPACE=true
SKIP_PULL=false

for arg in "$@"; do
    case "$arg" in
        --system)    RUN_XSPACE=false ;;
        --xspace)    RUN_SYSTEM=false ;;
        --skip-pull) SKIP_PULL=true   ;;
        --help|-h)   usage; exit 0    ;;
        *) echo "updatex: unknown option '$arg'"; usage; exit 1 ;;
    esac
done

# ─────────────────────────────────────────────────────────────────────────────
# SYSTEM UPDATE (Fedora — dnf)
# ─────────────────────────────────────────────────────────────────────────────

if [[ "$RUN_SYSTEM" == true ]]; then
    hr "System update"

    log "dnf upgrade..."
    sudo dnf upgrade --refresh -y
    ok "dnf upgrade complete"

    log "flatpak update..."
    flatpak update -y 2>/dev/null && ok "flatpak update complete" \
        || warn "flatpak update failed (non-fatal)"

    log "dnf autoremove..."
    sudo dnf autoremove -y 2>/dev/null || true
    ok "autoremove complete"
fi

# ─────────────────────────────────────────────────────────────────────────────
# XSPACE REPO UPDATE
# ─────────────────────────────────────────────────────────────────────────────

if [[ "$RUN_XSPACE" == true ]]; then
    hr "XSpace update"

    if [[ ! -f "$_UPDATE_SCRIPT" ]]; then
        echo ""
        echo "  ✗ orchestrator update script not found at $_UPDATE_SCRIPT"
        echo "  CONFIGURE_DIR in xspace.conf is set to: $CONFIGURE_DIR"
        echo "  Verify the folder name matches."
        exit 1
    fi

    if [[ "$SKIP_PULL" == true ]]; then
        exec "$_UPDATE_SCRIPT" --skip-pull
    else
        exec "$_UPDATE_SCRIPT"
    fi
fi

echo ""
ok "All done."
