#!/usr/bin/env bash
# GitSpace — Interactive Pull Request helper (git-prx) — enhanced
# Path: bin/git-prx

set -euo pipefail
IFS=$'\n\t'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$SCRIPT_DIR/../lib"
TEMPLATES_DIR="$(cd "$SCRIPT_DIR/../templates" 2>/dev/null || echo "$SCRIPT_DIR/../templates")"
LOG_DIR="${HOME}/.gitspace/logs"
mkdir -p "$LOG_DIR"

for lib in validation.sh formatting.sh safety.sh ui.sh; do
    if [[ -f "$LIB_DIR/$lib" ]]; then
        source "$LIB_DIR/$lib"
    else
        echo "ERROR: missing $LIB_DIR/$lib" >&2
        exit 1
    fi
done

usage() {
    cat <<EOF
git-prx — GitSpace PR helper (enhanced)
Usage: git prx [flags]
Options:
  --template <name>        Use a PR template from templates/pr/<name>.md (default: default.md)
  --other flags ... same as before ...
EOF
}

# parse (kept compact; see previous version for all flags)
PUSH=false; OPEN=false; DRAFT=false; AUTO_MERGE=false; AUTO_YES=false; NON_INTERACTIVE=false
CREATE_BRANCH=""; BASE_BRANCH="main"; HEAD_BRANCH=""; TITLE_ARG=""; BODY_FILE=""; REVIEWERS=""; ASSIGNEES=""; LABELS=""; TEMPLATE_NAME="default.md"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --template) TEMPLATE_NAME="$2"; shift 2 ;;
        --create-branch) CREATE_BRANCH="$2"; shift 2 ;;
        --from) HEAD_BRANCH="$2"; shift 2 ;;
        --base) BASE_BRANCH="$2"; shift 2 ;;
        --title) TITLE_ARG="$2"; shift 2 ;;
        --body-file) BODY_FILE="$2"; shift 2 ;;
        --reviewers) REVIEWERS="$2"; shift 2 ;;
        --assignees) ASSIGNEES="$2"; shift 2 ;;
        --labels) LABELS="$2"; shift 2 ;;
        --draft) DRAFT=true; shift ;;
        --push) PUSH=true; shift ;;
        --open) OPEN=true; shift ;;
        --auto-merge) AUTO_MERGE=true; shift ;;
        -y|--yes) AUTO_YES=true; shift ;;
        --non-interactive) NON_INTERACTIVE=true; shift ;;
        -h|--help) usage; exit 0 ;;
        *) echo "Unknown arg: $1"; usage; exit 1 ;;
    esac
done

# repo checks
if ! git rev-parse --git-dir > /dev/null 2>&1; then print_error "Not a git repo"; exit 1; fi
REPO_ROOT="$(git rev-parse --show-toplevel)"; cd "$REPO_ROOT"
CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD || echo "HEAD")"

# create branch if requested
if [[ -n "$CREATE_BRANCH" ]]; then
    if ! validate_branch_name "$CREATE_BRANCH"; then
        print_error "Branch name invalid; aborting."
        exit 1
    fi
    git checkout -b "$CREATE_BRANCH"
    CURRENT_BRANCH="$CREATE_BRANCH"
    print_info "Created branch $CREATE_BRANCH"
fi

HEAD_BRANCH="${HEAD_BRANCH:-$CURRENT_BRANCH}"
if [[ "$HEAD_BRANCH" == "main" || "$HEAD_BRANCH" == "master" ]]; then print_error "Cannot create PR from main/master"; exit 1; fi

# ensure gh exists
if ! command -v gh >/dev/null 2>&1; then print_error "gh not installed"; exit 1; fi

# push if requested
if [[ "$PUSH" == true ]]; then
    git push -u origin "$HEAD_BRANCH"
fi

# build title if not provided
COMMITS_RANGE="$BASE_BRANCH..$HEAD_BRANCH"
COMMITS="$(git --no-pager log --pretty=format:'%s' "$COMMITS_RANGE" 2>/dev/null || true)"
TITLE="${TITLE_ARG:-$(printf '%s\n' "$COMMITS" | head -n1 || echo "WIP: $HEAD_BRANCH")}"

# build body: use template if present
BODY=""
TEMPLATE_PATH="$TEMPLATES_DIR/pr/$TEMPLATE_NAME"
if [[ -n "$BODY_FILE" && -f "$BODY_FILE" ]]; then
    BODY="$(cat "$BODY_FILE")"
elif [[ -f "$TEMPLATE_PATH" ]]; then
    # seed template with commit list and diffstat
    COMMITS_LIST="$(git --no-pager log --pretty=format:'- %s (%h)' "$COMMITS_RANGE" 2>/dev/null || true)"
    DIFFSTAT="$(git --no-pager diff --stat "$BASE_BRANCH...$HEAD_BRANCH" 2>/dev/null || true)"
    BODY="$(sed -e \"s|{{COMMITS}}|$COMMITS_LIST|g\" -e \"s|{{DIFFSTAT}}|$DIFFSTAT|g\" "$TEMPLATE_PATH")"
else
    COMMITS_LIST="$(git --no-pager log --pretty=format:'- %s (%h)' "$COMMITS_RANGE" 2>/dev/null || true)"
    DIFFSTAT="$(git --no-pager diff --stat "$BASE_BRANCH...$HEAD_BRANCH" 2>/dev/null || true)"
    BODY="Changes in $HEAD_BRANCH -> $BASE_BRANCH\n\nCommits:\n$COMMITS_LIST\n\nDiffstat:\n$DIFFSTAT"
fi

# reviewer suggestions: if none provided, attempt suggestions
if [[ -z "$REVIEWERS" ]]; then
    mapfile -t staged_files < <(git diff --cached --name-only || true)
    SUGG="$(suggest_reviewers "${staged_files[@]:-}")"
    if [[ -n "$SUGG" ]]; then
        REVIEWERS="$SUGG"
        print_info "Suggested reviewers: $REVIEWERS"
    fi
fi

# interactive edit of title/body
if [[ "$NON_INTERACTIVE" != true ]]; then
    TMP="$(mktemp)"
    printf "%s" "$TITLE" > "$TMP"
    if command -v code >/dev/null 2>&1; then eval "code --wait \"$TMP\""; else ${EDITOR:-vi} "$TMP"; fi
    TITLE="$(cat "$TMP")"; rm -f "$TMP"

    TMPB="$(mktemp)"; printf "%s" "$BODY" > "$TMPB"
    if command -v code >/dev/null 2>&1; then eval "code --wait \"$TMPB\""; else ${EDITOR:-vi} "$TMPB"; fi
    BODY="$(cat "$TMPB")"; rm -f "$TMPB"
fi

# preview
echo "=== PR Preview ==="
echo "Title: $TITLE"
echo
echo "$BODY"
echo
echo "Base: $BASE_BRANCH  Head: $HEAD_BRANCH"
echo "Reviewers: $REVIEWERS"
echo "Labels: $LABELS"
echo "Draft: $DRAFT"
echo "Push: $PUSH"
echo "=================="
if [[ "$AUTO_YES" != true ]]; then
    ! prompt_confirm "Create PR?" && { print_error "Canceled"; exit 1; }
fi

# build and execute gh command. Note: pass title and body as args safely
GH_ARGS=(pr create --base "$BASE_BRANCH" --head "$HEAD_BRANCH" --title "$TITLE" --body "$BODY")
$DRAFT && GH_ARGS+=(--draft)
# add reviewers/assignees/labels
if [[ -n "$REVIEWERS" ]]; then IFS=',' read -ra RARR <<< "$REVIEWERS"; for r in "${RARR[@]}"; do GH_ARGS+=(--reviewer "$r"); done; fi
if [[ -n "$ASSIGNEES" ]]; then IFS=',' read -ra AARR <<< "$ASSIGNEES"; for a in "${AARR[@]}"; do GH_ARGS+=(--assignee "$a"); done; fi
if [[ -n "$LABELS" ]]; then IFS=',' read -ra LARR <<< "$LABELS"; for l in "${LARR[@]}"; do GH_ARGS+=(--label "$l"); done; fi

print_info "Creating PR..."
# execute, fallback to verbose on error
if ! "${GH_ARGS[@]}" >/dev/null 2>&1; then
    print_error "gh pr create failed; attempting to run without suppression..."
    "${GH_ARGS[@]}" || { print_error "gh pr create failed"; exit 1; }
fi

PR_URL="$(gh pr view --json url --jq .url 2>/dev/null || true)"
if [[ -z "$PR_URL" ]]; then PR_URL="$(gh pr list --head "$HEAD_BRANCH" --json url --jq '.[0].url' 2>/dev/null || true)"; fi
print_success "PR created: $PR_URL"

# open in browser if requested
if [[ "$OPEN" == true && -n "$PR_URL" ]]; then
    if command -v gh >/dev/null 2>&1; then gh pr view --web "$PR_URL" >/dev/null 2>&1 || true; fi
    if command -v xdg-open >/dev/null 2>&1; then xdg-open "$PR_URL" >/dev/null 2>&1 || true; fi
fi

# optionally auto-merge (same logic as previous version)
if [[ "$AUTO_MERGE" == true && -n "$PR_URL" ]]; then
    PR_NUMBER="$(gh pr view --json number --jq .number)"
    attempts=0; max_attempts=30; sleep_seconds=10
    while [[ $attempts -lt $max_attempts ]]; do
        mergeable_status="$(gh pr view "$PR_NUMBER" --json mergeStateStatus --jq .mergeStateStatus 2>/dev/null || echo "")"
        if [[ "$mergeable_status" == "MERGEABLE" ]]; then
            print_info "Merging..."
            gh pr merge "$PR_NUMBER" --squash --delete-branch || { print_error "Auto-merge failed"; break; }
            print_success "PR merged."
            break
        fi
        attempts=$((attempts+1)); sleep "$sleep_seconds"
    done
fi

# log PR
printf "%s\t%s\t%s\t%s\t%s\n" "$(date --iso-8601=seconds)" "$REPO_ROOT" "$HEAD_BRANCH" "$BASE_BRANCH" "$PR_URL" >> "${LOG_DIR}/prs.log"

exit 0