#!/usr/bin/env bash
# git-space/bin/commitx
#
# GitSpace commit helper — interactive conventional commit + smart push.
# Sources git-space/lib/{validation,formatting,safety,ui}.sh if present.

# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   v1.0.0 — Full UX rewrite. Colored structured output throughout.
#             Post-commit push flow: detects remote + branch + upstream tracking.
#             New flags: --push (auto-push), --no-push (skip prompt).
#             Branch context header: shows current branch, tracking remote,
#             recent commits, and repo summary before prompting.
#             Commit type auto-suggested from branch prefix.
#             Scope auto-suggested from branch slug.
#             Push sets --set-upstream automatically if tracking not configured.
#             Works for private repos, first commits, detached HEAD gracefully.
#             Preserves all v0.x functionality and flags.
#   v0.x.x — Original commitx: staging, conventional commit, lib integration.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail
IFS=$'\n\t'

# ─────────────────────────────────────────────────────────────────────────────
# BOOTSTRAP
# ─────────────────────────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
LIB_DIR="$SCRIPT_DIR/../lib"
LOG_DIR="${HOME}/.gitspace/logs"
mkdir -p "$LOG_DIR"

# ─────────────────────────────────────────────────────────────────────────────
# COLORS
# ─────────────────────────────────────────────────────────────────────────────

if [[ -t 1 && "${NO_COLOR:-}" != "1" ]]; then
  R=$'\033[0m'        BOLD=$'\033[1m'      DIM=$'\033[2m'
  GRN=$'\033[0;32m'   YLW=$'\033[0;33m'   BLU=$'\033[0;34m'
  CYN=$'\033[0;36m'   RED=$'\033[0;31m'   WHT=$'\033[1;37m'
  GRY=$'\033[0;90m'   MGT=$'\033[0;35m'   ITL=$'\033[3m'
else
  R='' BOLD='' DIM='' GRN='' YLW='' BLU='' CYN='' RED='' WHT='' GRY='' MGT='' ITL=''
fi

# ─────────────────────────────────────────────────────────────────────────────
# UI HELPERS
# ─────────────────────────────────────────────────────────────────────────────

_ok()     { echo -e "  ${GRN}✓${R}  $*"; }
_info()   { echo -e "  ${BLU}›${R}  $*"; }
_warn()   { echo -e "  ${YLW}⚠${R}   $*"; }
_err()    { echo -e "  ${RED}✗${R}  $*" >&2; }
_dim()    { echo -e "     ${GRY}$*${R}"; }
_label()  { echo -e "  ${DIM}$*${R}"; }
_hr()     { echo -e "\n  ${DIM}────────────────────────────────────────────────────────${R}"; }
_section(){ echo -e "\n  ${BOLD}${WHT}$*${R}"; }
_prompt() { printf "  ${CYN}%s${R} " "$1"; }

# ─────────────────────────────────────────────────────────────────────────────
# LOAD LIBS (with safe fallbacks — commitx works even without lib files)
# ─────────────────────────────────────────────────────────────────────────────

for _lib in validation.sh formatting.sh safety.sh ui.sh; do
  [[ -f "$LIB_DIR/$_lib" ]] && source "$LIB_DIR/$_lib" 2>/dev/null || true
done

# Fallback implementations — used only when lib functions are absent
if ! declare -f validate_commit_type &>/dev/null; then
  validate_commit_type() {
    case "$1" in feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert) return 0 ;; *) return 1 ;; esac
  }
fi
if ! declare -f prevent_commit_on_main &>/dev/null; then
  prevent_commit_on_main() {
    local b; b="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"
    [[ "$b" == "main" || "$b" == "master" ]] && { _err "Cannot commit directly on ${b}."; return 1; }
    return 0
  }
fi
if ! declare -f validate_staged_changes &>/dev/null; then
  validate_staged_changes() {
    [[ -z "$(git diff --cached --name-only 2>/dev/null)" ]] && { _err "No staged changes."; return 1; } || return 0
  }
fi
if ! declare -f wrap_body &>/dev/null; then
  wrap_body() { echo "$1" | fold -s -w 72; }
fi
if ! declare -f build_commit_header &>/dev/null; then
  build_commit_header() {
    local type="$1" scope="$2" summary="$3"
    [[ -n "$scope" ]] && echo "$type($scope): $summary" || echo "$type: $summary"
  }
fi

# ─────────────────────────────────────────────────────────────────────────────
# USAGE
# ─────────────────────────────────────────────────────────────────────────────

_usage() {
  cat <<EOF

  ${BOLD}commitx${R} — GitSpace conventional commit helper

  ${BOLD}USAGE${R}
    commitx [flags]

  ${BOLD}COMMIT FLAGS${R}
    --type <type>        Commit type: feat fix docs style refactor test chore
                                       perf ci build revert
    --scope <scope>      Scope (module or folder name)
    --summary <text>     One-line summary (≤50 chars)
    --body-file <file>   Read commit body from file
    --footer-file <file> Read footer from file
    --amend              Amend the last commit
    --signoff            Add Signed-off-by trailer
    --gpg                GPG-sign the commit (-S)
    --no-stage           Skip 'git add --all' (stage manually first)
    --non-interactive    Fail if any required field is missing
    --editor <cmd>       Editor command (default: \$EDITOR or code or nano)

  ${BOLD}PUSH FLAGS${R}
    --push / -P          Auto-push after commit (no prompt)
    --no-push            Skip push entirely (no prompt)

  ${BOLD}CONTROL FLAGS${R}
    --yes / -y           Skip commit confirmation prompt
    --help               Show this help

  ${BOLD}EXAMPLES${R}
    commitx
    commitx --push
    commitx --type feat --scope auth --summary "add OAuth2 login" --push
    commitx --amend --no-push

EOF
}

# ─────────────────────────────────────────────────────────────────────────────
# PARSE FLAGS
# ─────────────────────────────────────────────────────────────────────────────

AMEND_MODE=false
SIGNOFF=false
GPG_SIGN=false
AUTO_YES=false
NON_INTERACTIVE=false
NO_STAGE=false
AUTO_PUSH=false
NO_PUSH=false
EDITOR_CMD=""
declare -A ARGS

while [[ $# -gt 0 ]]; do
  case "$1" in
    --type)            ARGS[type]="$2";      shift 2 ;;
    --scope)           ARGS[scope]="$2";     shift 2 ;;
    --summary)         ARGS[summary]="$2";   shift 2 ;;
    --body-file)       ARGS[body_file]="$2"; shift 2 ;;
    --footer-file)     ARGS[footer_file]="$2"; shift 2 ;;
    --amend)           AMEND_MODE=true;      shift ;;
    --signoff)         SIGNOFF=true;         shift ;;
    --gpg)             GPG_SIGN=true;        shift ;;
    -y|--yes)          AUTO_YES=true;        shift ;;
    --push|-P)         AUTO_PUSH=true;       shift ;;
    --no-push)         NO_PUSH=true;         shift ;;
    --editor)          EDITOR_CMD="$2";      shift 2 ;;
    --non-interactive) NON_INTERACTIVE=true; shift ;;
    --no-stage)        NO_STAGE=true;        shift ;;
    -h|--help)         _usage; exit 0 ;;
    *) _err "Unknown flag: $1"; _usage; exit 1 ;;
  esac
done

# ─────────────────────────────────────────────────────────────────────────────
# GIT CONTEXT — gathered once, used throughout
# ─────────────────────────────────────────────────────────────────────────────

if ! git rev-parse --git-dir &>/dev/null; then
  _err "Not inside a Git repository."
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

REPO_HAS_COMMITS=true
git rev-parse --verify HEAD &>/dev/null || REPO_HAS_COMMITS=false

CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'HEAD')"
[[ "$REPO_HAS_COMMITS" == false ]] && CURRENT_BRANCH="(initial)"

# Remote detection — prefer 'origin', fall back to first remote
ALL_REMOTES=()
while IFS= read -r r; do ALL_REMOTES+=("$r"); done < <(git remote 2>/dev/null || true)

PUSH_REMOTE=""
if printf '%s\n' "${ALL_REMOTES[@]+"${ALL_REMOTES[@]}"}" | grep -qx 'origin' 2>/dev/null; then
  PUSH_REMOTE="origin"
elif (( ${#ALL_REMOTES[@]} > 0 )); then
  PUSH_REMOTE="${ALL_REMOTES[0]}"
fi

REMOTE_URL=""
[[ -n "$PUSH_REMOTE" ]] && REMOTE_URL="$(git remote get-url "$PUSH_REMOTE" 2>/dev/null || echo '')"

# Upstream tracking for current branch
UPSTREAM="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo '')"

# Branch-type auto-detection for smart defaults
BRANCH_TYPE=""
BRANCH_SLUG=""
if [[ "$CURRENT_BRANCH" =~ ^(feat|feature|fix|hotfix|docs|style|refactor|test|chore|perf|ci|build|revert)/([^/]+)/?.*$ ]]; then
  raw_type="${BASH_REMATCH[1]}"
  BRANCH_SLUG="${BASH_REMATCH[2]}"
  # Normalise common aliases
  case "$raw_type" in feature) BRANCH_TYPE="feat" ;; hotfix) BRANCH_TYPE="fix" ;; *) BRANCH_TYPE="$raw_type" ;; esac
fi

# Ticket detection from branch name
AUTO_TICKET=""
if [[ "$CURRENT_BRANCH" =~ ([A-Z]{2,10}-[0-9]+) ]]; then
  AUTO_TICKET="${BASH_REMATCH[1]}"
elif [[ "$CURRENT_BRANCH" =~ \#([0-9]+) ]]; then
  AUTO_TICKET="#${BASH_REMATCH[1]}"
fi

# ─────────────────────────────────────────────────────────────────────────────
# BANNER — context header before any prompts
# ─────────────────────────────────────────────────────────────────────────────

echo ""
echo -e "  ${BOLD}${WHT}commitx${R}${GRY} — GitSpace commit helper${R}"
_hr

echo ""
# Branch
local_indicator=""
[[ "$CURRENT_BRANCH" == "main" || "$CURRENT_BRANCH" == "master" ]] && local_indicator=" ${YLW}⚠ protected${R}"
echo -e "  ${GRY}branch  ${R}${CYN}${CURRENT_BRANCH}${R}${local_indicator}"

# Remote + tracking
if [[ -n "$PUSH_REMOTE" ]]; then
  if [[ -n "$UPSTREAM" ]]; then
    echo -e "  ${GRY}remote  ${R}${PUSH_REMOTE}  ${GRY}tracking ${CYN}${UPSTREAM}${R}"
  else
    echo -e "  ${GRY}remote  ${R}${PUSH_REMOTE}  ${GRY}(no upstream — will set on push)${R}"
  fi
else
  echo -e "  ${GRY}remote  ${YLW}none configured${R}"
fi

# Recent commits
if [[ "$REPO_HAS_COMMITS" == true ]]; then
  echo ""
  echo -e "  ${GRY}recent commits${R}"
  while IFS= read -r line; do
    echo -e "  ${GRY}│${R}  $line"
  done < <(git log --oneline -4 --color=never 2>/dev/null | \
    sed "s/^\([a-f0-9]*\) /${CYN}\1${R} /" || true)
fi

# ─────────────────────────────────────────────────────────────────────────────
# STAGING
# ─────────────────────────────────────────────────────────────────────────────

_section "Staging"

if [[ "$NO_STAGE" == true ]]; then
  _info "Skipping auto-stage  ${GRY}(--no-stage)${R}"
else
  _info "Staging all changes  ${GRY}(git add --all)${R}"
  git add --all
fi

# Parse porcelain status
declare -a staged_list=() unstaged_list=() untracked_list=()
staged_added=0; staged_modified=0; staged_deleted=0; staged_renamed=0

while IFS= read -r raw || [[ -n "${raw:-}" ]]; do
  line="${raw:-}"
  [[ -z "${line//[[:space:]]/}" ]] && continue
  code="${line:0:2}"
  file="${line:3}"
  ix="${code:0:1}"
  wt="${code:1:1}"

  if [[ "$code" == "??" ]]; then
    untracked_list+=("$file"); continue
  fi
  if [[ "$ix" != " " ]]; then
    staged_list+=("$file")
    case "$ix" in
      A) (( ++staged_added   )) ;;
      M) (( ++staged_modified )) ;;
      D) (( ++staged_deleted  )) ;;
      R) (( ++staged_renamed  )) ;;
    esac
  fi
  [[ "$wt" != " " ]] && unstaged_list+=("$file")
done < <(git status --porcelain=1 2>/dev/null || true)

staged_count=${#staged_list[@]}
unstaged_count=${#unstaged_list[@]}
untracked_count=${#untracked_list[@]}

echo ""
if (( staged_count == 0 && unstaged_count == 0 && untracked_count == 0 )); then
  echo -e "  ${GRY}Working tree clean — nothing to commit.${R}"
else
  if (( staged_count > 0 )); then
    echo -e "  ${GRN}staged${R}     ${staged_count} file(s)  ${GRY}+${staged_added} ~${staged_modified} -${staged_deleted} ↔${staged_renamed}${R}"
    for f in "${staged_list[@]:0:12}"; do _dim "${f}"; done
    (( staged_count > 12 )) && _dim "… and $(( staged_count - 12 )) more"
  else
    echo -e "  ${GRY}staged${R}     ${YLW}none${R}"
  fi
  (( unstaged_count > 0 )) && echo -e "  ${YLW}unstaged${R}   ${unstaged_count} modified (not staged)"
  (( untracked_count > 0 )) && echo -e "  ${GRY}untracked  ${untracked_count} file(s)${R}"
fi

# ─────────────────────────────────────────────────────────────────────────────
# SAFETY CHECKS
# ─────────────────────────────────────────────────────────────────────────────

if [[ "$AMEND_MODE" != true ]]; then
  if [[ "$REPO_HAS_COMMITS" == true ]]; then
    prevent_commit_on_main || exit 1
    validate_staged_changes || exit 1
  fi
else
  [[ "$REPO_HAS_COMMITS" == false ]] && { _err "--amend requires at least one prior commit."; exit 1; }
fi

# ─────────────────────────────────────────────────────────────────────────────
# EDITOR DETECTION
# ─────────────────────────────────────────────────────────────────────────────

_detect_editor() {
  [[ -n "$EDITOR_CMD" ]]           && { echo "$EDITOR_CMD"; return; }
  command -v code  &>/dev/null     && { echo "code --wait"; return; }
  [[ -n "${VISUAL:-}" ]]           && { echo "$VISUAL"; return; }
  [[ -n "${EDITOR:-}" ]]           && { echo "$EDITOR"; return; }
  command -v nano  &>/dev/null     && { echo "nano"; return; }
  command -v vi    &>/dev/null     && { echo "vi"; return; }
  echo ""
}
EDITOR_FINAL="$(_detect_editor)"

_compose_with_editor() {
  local tmpf; tmpf="$(mktemp)"
  trap 'rm -f "$tmpf"' RETURN
  [[ -n "${1:-}" && -f "${1:-}" ]] && cat "$1" > "$tmpf"
  if [[ -n "$EDITOR_FINAL" ]]; then
    if [[ "$EDITOR_FINAL" == *" "* ]]; then eval "$EDITOR_FINAL \"$tmpf\""
    else "$EDITOR_FINAL" "$tmpf"; fi
    cat "$tmpf"
  else
    echo -e "  ${GRY}No editor found. Paste text; end with a lone '.' on its own line.${R}" >&2
    local out=""
    while IFS= read -r l; do [[ "$l" == "." ]] && break; out+="$l"$'\n'; done
    printf "%s" "$out"
  fi
}

# ─────────────────────────────────────────────────────────────────────────────
# COMMIT FIELDS — interactive collection
# ─────────────────────────────────────────────────────────────────────────────

_section "Commit message"
echo ""

TYPE="${ARGS[type]:-}"
SCOPE="${ARGS[scope]:-}"
SUMMARY="${ARGS[summary]:-}"
BODY=""
FOOTER=""

[[ -n "${ARGS[body_file]:-}"   && -f "${ARGS[body_file]}" ]]   && BODY="$(cat "${ARGS[body_file]}")"
[[ -n "${ARGS[footer_file]:-}" && -f "${ARGS[footer_file]}" ]] && FOOTER="$(cat "${ARGS[footer_file]}")"

# ── Type ─────────────────────────────────────────────────────────────────────

VALID_TYPES=(feat fix docs style refactor test chore perf ci build revert)

if [[ -z "$TYPE" ]]; then
  if [[ "$NON_INTERACTIVE" == true ]]; then
    _err "--type required in non-interactive mode"; exit 1
  fi

  # Show type menu with suggested type highlighted
  echo -e "  ${GRY}Type${R}"
  for i in "${!VALID_TYPES[@]}"; do
    t="${VALID_TYPES[$i]}"
    num="$(( i + 1 ))"
    if [[ "$t" == "$BRANCH_TYPE" ]]; then
      printf "    ${CYN}[%2d]${R}  ${BOLD}%-10s${R}  ${GRY}← branch suggestion${R}\n" "$num" "$t"
    else
      printf "    ${GRY}[%2d]${R}  %-10s\n" "$num" "$t"
    fi
  done
  echo ""

  while true; do
    if [[ -n "$BRANCH_TYPE" ]]; then
      _prompt "Select type  [suggested: ${BOLD}${BRANCH_TYPE}${R}${CYN}]  number or name (Enter = ${BRANCH_TYPE}): "
    else
      _prompt "Select type  number or name: "
    fi
    IFS= read -r _input
    _input="${_input//[[:space:]]/}"

    # Enter with suggested type
    if [[ -z "$_input" && -n "$BRANCH_TYPE" ]]; then
      TYPE="$BRANCH_TYPE"; break
    fi
    # Numeric selection
    if [[ "$_input" =~ ^[0-9]+$ ]] && (( _input >= 1 && _input <= ${#VALID_TYPES[@]} )); then
      TYPE="${VALID_TYPES[$(( _input - 1 ))]}"; break
    fi
    # Name entry
    if validate_commit_type "$_input" 2>/dev/null; then
      TYPE="$_input"; break
    fi
    _warn "Invalid type. Enter a number (1–${#VALID_TYPES[@]}) or a valid type name."
  done
  _ok "Type: ${BOLD}${TYPE}${R}"
else
  validate_commit_type "$TYPE" || { _err "Invalid type: $TYPE"; exit 1; }
  _ok "Type: ${BOLD}${TYPE}${R}  ${GRY}(from --type flag)${R}"
fi

echo ""

# ── Scope ─────────────────────────────────────────────────────────────────────

if [[ -z "$SCOPE" && "$NON_INTERACTIVE" != true ]]; then
  if [[ -n "$BRANCH_SLUG" ]]; then
    _prompt "Scope  ${GRY}[Enter = ${CYN}${BRANCH_SLUG}${GRY}, or type custom, or leave blank]:${R} "
  else
    _prompt "Scope  ${GRY}(optional — module or folder):${R} "
  fi
  IFS= read -r SCOPE
  SCOPE="${SCOPE//[[:space:]]/}"
  if [[ -z "$SCOPE" && -n "$BRANCH_SLUG" ]]; then
    SCOPE="$BRANCH_SLUG"
    _dim "Using branch slug: ${SCOPE}"
  fi
fi

# ── Summary ───────────────────────────────────────────────────────────────────

if [[ -z "$SUMMARY" ]]; then
  if [[ "$NON_INTERACTIVE" == true ]]; then
    _err "--summary required in non-interactive mode"; exit 1
  fi
  echo ""
  while true; do
    _prompt "Summary  ${GRY}(≤50 chars):${R} "
    IFS= read -r SUMMARY
    SUMMARY="${SUMMARY#"${SUMMARY%%[^[:space:]]*}"}"
    SUMMARY="${SUMMARY%"${SUMMARY##*[^[:space:]]}"}"
    local_len=${#SUMMARY}
    if [[ -n "$SUMMARY" && $local_len -le 50 ]]; then break; fi
    _warn "Summary must be 1–50 chars (got ${local_len})."
  done
else
  SUMMARY="${SUMMARY#"${SUMMARY%%[^[:space:]]*}"}"
  SUMMARY="${SUMMARY%"${SUMMARY##*[^[:space:]]}"}"
  (( ${#SUMMARY} > 50 )) && { _err "Summary too long (${#SUMMARY} chars, max 50)."; exit 1; }
fi

# ── Body (editor) ─────────────────────────────────────────────────────────────

if [[ -z "$BODY" && "$NON_INTERACTIVE" != true ]]; then
  echo ""
  _prompt "Add body?  ${GRY}[y/N]:${R} "
  IFS= read -r _want_body
  if [[ "${_want_body,,}" == "y" ]]; then
    _info "Opening editor for commit body..."
    BODY="$(_compose_with_editor "${ARGS[body_file]:-}")"
  fi
fi

# ── Footer / ticket ───────────────────────────────────────────────────────────

if [[ -z "$FOOTER" && -n "$AUTO_TICKET" ]]; then
  FOOTER="Closes $AUTO_TICKET"
fi

if [[ -z "${ARGS[footer_file]:-}" && "$NON_INTERACTIVE" != true ]]; then
  echo ""
  if [[ -n "$FOOTER" ]]; then
    _info "Footer:  ${GRY}${FOOTER}${R}"
    _prompt "Edit footer?  ${GRY}[y/N]:${R} "
    IFS= read -r _edit_footer
    if [[ "${_edit_footer,,}" == "y" ]]; then
      FOOTER="$(_compose_with_editor <(echo "$FOOTER"))"
    fi
  else
    _prompt "Footer  ${GRY}(optional — Closes #123, Co-authored-by, etc):${R} "
    IFS= read -r FOOTER
  fi
fi

# ─────────────────────────────────────────────────────────────────────────────
# BUILD COMMIT MESSAGE
# ─────────────────────────────────────────────────────────────────────────────

_clean() { echo "$1" | sed -E 's/[[:space:]]+$//g' | sed -E ':a;N;$!ba;s/\n{3,}/\n\n/g'; }

BODY="$(wrap_body "$(_clean "$BODY")")"
FOOTER="$(wrap_body "$(_clean "$FOOTER")")"
[[ "$SIGNOFF" == true ]] && {
  _sig="Signed-off-by: $(git config user.name 2>/dev/null || echo 'Unknown') <$(git config user.email 2>/dev/null || echo 'unknown')>"
  FOOTER="${FOOTER:+${FOOTER}$'\n\n'}${_sig}"
}

HEADER="$(build_commit_header "$TYPE" "$SCOPE" "$SUMMARY")"
COMMIT_MSG="$HEADER"
[[ -n "$BODY" ]]   && COMMIT_MSG+=$'\n\n'"$BODY"
[[ -n "$FOOTER" ]] && COMMIT_MSG+=$'\n\n'"$FOOTER"

# ─────────────────────────────────────────────────────────────────────────────
# PREVIEW + CONFIRM
# ─────────────────────────────────────────────────────────────────────────────

_section "Preview"
echo ""
echo -e "  ${BOLD}${CYN}┌─ commit message ───────────────────────────────────────${R}"
while IFS= read -r _l; do
  echo -e "  ${BOLD}${CYN}│${R}  ${_l}"
done <<< "$COMMIT_MSG"
echo -e "  ${BOLD}${CYN}└────────────────────────────────────────────────────────${R}"

if [[ "$REPO_HAS_COMMITS" == true ]]; then
  echo ""
  _label "staged diff"
  git --no-pager diff --cached --stat 2>/dev/null | while IFS= read -r _l; do
    echo -e "  ${GRY}${_l}${R}"
  done
fi

echo ""

if [[ "$AUTO_YES" != true ]]; then
  _prompt "Commit?  ${GRY}[Y/n]:${R} "
  IFS= read -r _yn
  if [[ -n "${_yn:-}" && ! "${_yn,,}" =~ ^y ]]; then
    _err "Commit cancelled."
    exit 1
  fi
fi

# ─────────────────────────────────────────────────────────────────────────────
# COMMIT
# ─────────────────────────────────────────────────────────────────────────────

_section "Committing"
echo ""

COMMIT_FLAGS=()
[[ "$SIGNOFF"  == true ]] && COMMIT_FLAGS+=("-s")
[[ "$GPG_SIGN" == true ]] && COMMIT_FLAGS+=("-S")

if [[ "$AMEND_MODE" == true ]]; then
  git commit --amend -m "$COMMIT_MSG" "${COMMIT_FLAGS[@]+"${COMMIT_FLAGS[@]}"}"
elif [[ "$REPO_HAS_COMMITS" == false ]]; then
  git commit --allow-empty -m "$COMMIT_MSG" "${COMMIT_FLAGS[@]+"${COMMIT_FLAGS[@]}"}"
else
  git commit -m "$COMMIT_MSG" "${COMMIT_FLAGS[@]+"${COMMIT_FLAGS[@]}"}"
fi

LAST_COMMIT="$(git log -1 --pretty=format:'%C(cyan)%h%Creset %s' --color=always 2>/dev/null || true)"
_ok "Committed: ${LAST_COMMIT}"

# Log to file
TIMESTAMP="$(date --iso-8601=seconds 2>/dev/null || date -u +"%Y-%m-%dT%H:%M:%SZ")"
printf "%s\t%s\t%s\t%s\t%s\n" \
  "$TIMESTAMP" "$REPO_ROOT" "$CURRENT_BRANCH" "$TYPE" "$SUMMARY" \
  >> "${LOG_DIR}/commits.log" 2>/dev/null || true

# ─────────────────────────────────────────────────────────────────────────────
# PUSH
# ─────────────────────────────────────────────────────────────────────────────

_do_push() {
  if [[ -z "$PUSH_REMOTE" ]]; then
    _warn "No remote configured — push skipped."
    return 0
  fi

  local push_flags=()
  local set_upstream=false

  # Refresh upstream status (might have just been set by a prior push)
  local current_upstream
  current_upstream="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo '')"

  if [[ -z "$current_upstream" ]]; then
    push_flags+=("--set-upstream" "$PUSH_REMOTE" "$CURRENT_BRANCH")
    set_upstream=true
  fi

  echo ""
  _label "push target"
  echo -e "  ${GRY}remote${R}  ${CYN}${PUSH_REMOTE}${R}  ${GRY}${REMOTE_URL}${R}"
  echo -e "  ${GRY}branch${R}  ${CYN}${CURRENT_BRANCH}${R}"
  [[ "$set_upstream" == true ]] && echo -e "  ${GRY}note  ${R}  ${YLW}--set-upstream${R} ${GRY}(first push on this branch)${R}"
  echo ""

  if git push "${push_flags[@]+"${push_flags[@]}"}"; then
    echo ""
    _ok "Pushed  ${GRY}→ ${PUSH_REMOTE}/${CURRENT_BRANCH}${R}"
    TIMESTAMP="$(date --iso-8601=seconds 2>/dev/null || date -u +"%Y-%m-%dT%H:%M:%SZ")"
    printf "%s\t%s\t%s\tpush\t%s/%s\n" \
      "$TIMESTAMP" "$REPO_ROOT" "$CURRENT_BRANCH" "$PUSH_REMOTE" "$CURRENT_BRANCH" \
      >> "${LOG_DIR}/commits.log" 2>/dev/null || true
  else
    echo ""
    _err "Push failed."
    _dim "Manual retry:  git push ${push_flags[*]+"${push_flags[*]}"}"
    return 1
  fi
}

if [[ "$NO_PUSH" == true ]]; then
  : # explicitly skipped
elif [[ "$AUTO_PUSH" == true ]]; then
  _section "Pushing"
  _do_push
elif [[ -z "$PUSH_REMOTE" ]]; then
  : # no remote — nothing to prompt
else
  # Interactive push prompt
  _hr
  echo ""
  echo -e "  ${BOLD}Push to ${CYN}${PUSH_REMOTE}/${CURRENT_BRANCH}${R}${BOLD}?${R}"
  if [[ -z "$UPSTREAM" ]]; then
    echo -e "  ${GRY}(sets tracking: ${CYN}${PUSH_REMOTE}/${CURRENT_BRANCH}${GRY})${R}"
  fi
  echo ""
  _prompt "Push?  ${GRY}[Y/n]:${R} "
  IFS= read -r _push_yn
  if [[ -z "${_push_yn:-}" || "${_push_yn,,}" =~ ^y ]]; then
    _do_push
  else
    _info "Push skipped.  ${GRY}Run: git push${UPSTREAM:+ (tracking already set)}${R}"
  fi
fi

# ─────────────────────────────────────────────────────────────────────────────
# DONE
# ─────────────────────────────────────────────────────────────────────────────

echo ""
_hr
echo ""
echo -e "  ${GRN}${BOLD}Done.${R}"
echo ""
exit 0
